	for _, part in pairs(Workspace:GetPartsInPart(selectionPart)) do
		if part.Parent and part.Parent.Name == "Blocks" then
			table.insert(blocks, part)
		end
	end

	if #blocks == 0 then
		return nil, "No island blocks were found inside the selection."
	end

	return blocks
end

local function getSelectionOrigin(blocks)
	local minX = math.huge
	local minY = math.huge
	local minZ = math.huge

	for _, block in ipairs(blocks) do
		local pos = block.Position
		if pos.X < minX then
			minX = pos.X
		end
		if pos.Y < minY then
			minY = pos.Y
		end
		if pos.Z < minZ then
			minZ = pos.Z
		end
	end

	return Vector3.new(minX, minY, minZ)
end

local function buildSchematicData(blocks)
	local origin = getSelectionOrigin(blocks)
	local originCFrame = CFrame.new(origin)
	local data = {
		FormatVersion = 2,
		BlockSize = BLOCK_SIZE,
		Origin = { origin.X, origin.Y, origin.Z },
		Blocks = {}
	}

	table.sort(blocks, function(a, b)
		if a.Position.Y ~= b.Position.Y then
			return a.Position.Y < b.Position.Y
		end
		if a.Position.X ~= b.Position.X then
			return a.Position.X < b.Position.X
		end
		if a.Position.Z ~= b.Position.Z then
			return a.Position.Z < b.Position.Z
		end
		return a.Name < b.Name
	end)

	for _, block in ipairs(blocks) do
		local relative = originCFrame:ToObjectSpace(block.CFrame)
		local blockName = block.Name

		if not data.Blocks[blockName] then
			data.Blocks[blockName] = {}
		end

		table.insert(data.Blocks[blockName], {
			C = { relative.components(relative) }
		})
	end

	return data
end

local function stripComments(text)
	if type(text) ~= "string" then
		return nil
	end

	return text:gsub("%-%-.-\n", "\n")
end

local function decodeSchematicText(text)
	if type(text) ~= "string" or text == "" then
		return nil, "No schematic code was provided."
	end

	local cleaned = stripComments(text)
	local ok, decoded = pcall(function()
		return HttpService:JSONDecode(cleaned)
	end)

	if not ok then
		return nil, tostring(decoded)
	end

	return decoded, cleaned
end

