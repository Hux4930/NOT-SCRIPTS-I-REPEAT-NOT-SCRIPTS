-- Get NetManaged
local function getNetManaged()
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local ok, result = pcall(function()
        return ReplicatedStorage
            :WaitForChild("rbxts_include")
            :WaitForChild("node_modules")
            :WaitForChild("@rbxts")
            :WaitForChild("net")
            :WaitForChild("out")
            :WaitForChild("_NetManaged")
    end)
    
    if ok then return result end
    return nil
end

-- Try to capture hash from payload
local function tryCaptureHarvestHashFromPayload(payload, sourceLabel)
    if type(payload) ~= "table" then
        return false
    end
    
    -- Check for the dZnpyRtxna field (the hash field)
    if payload["dZnpyRtxna"] and type(payload["dZnpyRtxna"]) == "string" then
        capturedHash = payload["dZnpyRtxna"]
        
        -- Display hash with escaped characters
        local displayHash = capturedHash:gsub("[%z%c]", function(c)
            return string.format("\\x%02X", string.byte(c))
        end)
        hashLabel.Text = "Captured Hash: " .. displayHash:sub(1, 100)
        statusLabel.Text = "Status: ✓ Hash captured! Now you can auto harvest."
        
        print("=== HASH CAPTURED ===")
        print("Hash:", capturedHash)
        print("Source:", sourceLabel)
        print("=====================")
        
        return true
    end
    
    return false
end

-- Try to capture from args
local function tryCaptureHarvestHashFromArgs(args, sourceLabel)
    for _, arg in ipairs(args) do
        if tryCaptureHarvestHashFromPayload(arg, sourceLabel) then
            return true
        end
    end
    return false
end

-- Install the harvest capture hook
local function installHarvestCaptureHook()
    if captureInstalled then
        return true
    end
    
    -- Check if executor supports required functions
    if type(hookmetamethod) ~= "function" or type(getnamecallmethod) ~= "function" or type(newcclosure) ~= "function" then
        statusLabel.Text = "Status: Executor doesn't support harvest capture!"
        return false, "Executor missing required functions"
    end
    
    local netManaged = getNetManaged()
    if not netManaged then
        statusLabel.Text = "Status: Cannot find NetManaged!"
        return false, "NetManaged not found"
    end
    
    harvestRemote = netManaged:FindFirstChild("CLIENT_HARVEST_CROP_REQUEST")
    if not harvestRemote then
        statusLabel.Text = "Status: Cannot find harvest remote!"
        return false, "Harvest remote not found"
    end
    
    local oldNamecall
    oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
        local args = { ... }
        local method = getnamecallmethod()
        
        if method == "InvokeServer" and typeof(self) == "Instance" and self.Name == "CLIENT_HARVEST_CROP_REQUEST" then
            -- Check if this is a game call (not from our script)
            local isGameCall = true
            if type(checkcaller) == "function" then
                isGameCall = not checkcaller()
            end
            
            if isGameCall then
                local captured = tryCaptureHarvestHashFromArgs(args, "manual harvest")
                if captured then
                    task.spawn(function()
                        statusLabel.Text = "Status: Hash captured from manual harvest!"
                        hashLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
                        task.wait(2)
                        hashLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
                    end)
                end
            end
        end
        
        return oldNamecall(self, ...)
    end))
    
    captureInstalled = true
    statusLabel.Text = "Status: Capture hook installed! Manually harvest a crop."
    return true
end

-- Calculate distance
local function getDistance(pos1, pos2)
    return (pos1 - pos2).Magnitude
end

-- Find all harvestable objects (FIXED)
local function findHarvestableObjects()
    statusLabel.Text = "Status: Scanning for harvestable objects..."
    harvestableObjects = {}
    
    local player = game:GetService("Players").LocalPlayer
    local character = player.Character
    local playerPos = character and character.PrimaryPart and character.PrimaryPart.Position or Vector3.new(0, 0, 0)
    
    local Workspace = game:GetService("Workspace")
    
    -- Scan islands
    for _, island in pairs(Workspace.Islands:GetChildren()) do
        local blocks = island:FindFirstChild("Blocks")
        if blocks then
            for _, block in pairs(blocks:GetChildren()) do
                -- Get block name safely (handle numbers)
                local blockName = tostring(block.Name)
                local lowerName = blockName:lower()
                
                -- Check various harvestable types
                local isHarvestable = false
                local harvestType = "unknown"
                
                -- Check by name
                if lowerName:find("berry") or lowerName:find("bush") then
                    isHarvestable = true
                    harvestType = "berry"
                elseif lowerName:find("crop") or lowerName:find("wheat") or lowerName:find("carrot") or lowerName:find("potato") then
                    isHarvestable = true
                    harvestType = "crop"
                elseif lowerName:find("tree") or lowerName:find("wood") then
                    isHarvestable = true
                    harvestType = "tree"
                end
                
                -- Also check if it has Health (indicates harvestable block)
                if not isHarvestable and block:FindFirstChild("Health") then
                    isHarvestable = true
                    harvestType = "block"
                end
                
                if isHarvestable then
                    local position = block:IsA("BasePart") and block.Position or 
                                   (block:FindFirstChild("Position") and block.Position.Position) or
                                   Vector3.new(0, 0, 0)
                    
                    local distance = getDistance(playerPos, position)
                    
                    table.insert(harvestableObjects, {
                        name = blockName,
                        model = block,
                        island = tostring(island.Name),
                        position = position,
                        distance = distance,
                        type = harvestType
                    })
                end
            end
        end
    end
    
    -- Sort by distance (closest first)
    table.sort(harvestableObjects, function(a, b) 
        return a.distance < b.distance 
    end)
    
    -- Update display
    local listText = "Found " .. #harvestableObjects .. " objects (closest first):\n\n"
    for i, obj in ipairs(harvestableObjects) do
        listText = listText .. string.format("%d. %s [%s] - %.1f studs\n", i, obj.name, obj.type, obj.distance)
        if i >= 25 then
            listText = listText .. "\n... and " .. (#harvestableObjects - 25) .. " more"
            break
        end
    end
    
    listBox.Text = listText
    statusLabel.Text = "Status: Found " .. #harvestableObjects .. " harvestable objects"
    
    if #harvestableObjects == 0 then
        listBox.Text = "No harvestable objects found!\n\nMake sure you're near crops/berry bushes."
    end
end

-- Harvest a specific object
local function harvestObject(obj)
    if not obj or not obj.model then
        statusLabel.Text = "Status: Invalid object!"
        return false
    end
    
    if not capturedHash then
        statusLabel.Text = "Status: No hash captured! Manually harvest a crop first."
        return false
    end
    
    local player = game:GetService("Players").LocalPlayer
    local netManaged = getNetManaged()
    
    if not netManaged then
        statusLabel.Text = "Status: Cannot find NetManaged!"
        return false
    end
    
    local remote = netManaged:FindFirstChild("CLIENT_HARVEST_CROP_REQUEST")
    if not remote then
        statusLabel.Text = "Status: Cannot find harvest remote!"
        return false
    end
    
    statusLabel.Text = "Status: Harvesting " .. obj.name
    
    local success, result = pcall(function()
        return remote:InvokeServer({
            ["dZnpyRtxna"] = capturedHash,
            ["player"] = player,
            ["model"] = obj.model,
        })
    end)
    
    if success then
        statusLabel.Text = "Status: ✓ Harvested " .. obj.name
        print("Harvested:", obj.name, "Distance:", obj.distance)
        return true
    else
        statusLabel.Text = "Status: ✗ Failed to harvest " .. obj.name
        warn("Harvest failed:", result)
        return false
    end
end

-- Harvest closest object
local function harvestClosest()
    if #harvestableObjects == 0 then
        findHarvestableObjects()
    end
    
    if #harvestableObjects == 0 then
        statusLabel.Text = "Status: No objects to harvest!"
        return
    end
    
    if not capturedHash then
        statusLabel.Text = "Status: No hash! Manually harvest a crop first."
        return
    end
    
    -- Update distances to current position
    local player = game:GetService("Players").LocalPlayer
    local character = player.Character
    local playerPos = character and character.PrimaryPart and character.PrimaryPart.Position or Vector3.new(0, 0, 0)
    
    for _, obj in ipairs(harvestableObjects) do
        if obj.model and obj.model:IsDescendantOf(game:GetService("Workspace")) then
            obj.distance = getDistance(playerPos, obj.position)
        end
    end
    
    -- Re-sort by current distance
    table.sort(harvestableObjects, function(a, b) 
        return a.distance < b.distance 
    end)
    
    local closest = harvestableObjects[1]
    if closest then
        harvestObject(closest)
    else
        statusLabel.Text = "Status: No valid objects nearby!"
    end
end

-- Harvest all objects (closest first with 0.01s wait)
local function harvestAll()
    if #harvestableObjects == 0 then
        findHarvestableObjects()
    end
    
    if #harvestableObjects == 0 then
        statusLabel.Text = "Status: No objects to harvest!"
        return
    end
    
    if not capturedHash then
        statusLabel.Text = "Status: No hash! Manually harvest a crop first."
        return
    end
    
    -- Update all distances and sort
    local player = game:GetService("Players").LocalPlayer
    local character = player.Character
    local playerPos = character and character.PrimaryPart and character.PrimaryPart.Position or Vector3.new(0, 0, 0)
    
    for _, obj in ipairs(harvestableObjects) do
        if obj.model and obj.model:IsDescendantOf(game:GetService("Workspace")) then
            obj.distance = getDistance(playerPos, obj.position)
        else
            obj.distance = math.huge
        end
    end
    
    table.sort(harvestableObjects, function(a, b) 
        return a.distance < b.distance 
    end)
    
    statusLabel.Text = "Status: Harvesting all " .. #harvestableObjects .. " objects (closest first)..."
    
    local successCount = 0
    for i, obj in ipairs(harvestableObjects) do
        if obj.model and obj.model:IsDescendantOf(game:GetService("Workspace")) and obj.distance ~= math.huge then
            if harvestObject(obj) then
                successCount = successCount + 1
            end
            task.wait(0.01) -- 0.01 second wait
        end
    end
    
    statusLabel.Text = string.format("Status: Complete! Harvested %d/%d objects", successCount, #harvestableObjects)
    
    -- Refresh the list
    task.wait(1)
    findHarvestableObjects()
end

