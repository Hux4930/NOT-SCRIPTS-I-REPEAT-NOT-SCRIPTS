-- Variables
local harvestableObjects = {}
local capturedOffset = nil
var captureMode = false
local harvestRemote = nil

-- Safe string function
local function safeString(value)
    if value == nil then return "" end
    return tostring(value)
end

-- Find the harvest remote
local function findHarvestRemote()
    local rs = game:GetService("ReplicatedStorage")
    
    -- Try direct path
    local direct = rs:FindFirstChild("rbxts_include")
    if direct then
        local node = direct:FindFirstChild("node_modules")
        if node then
            local at = node:FindFirstChild("@rbxts")
            if at then
                local net = at:FindFirstChild("net")
                if net then
                    local out = net:FindFirstChild("out")
                    if out then
                        local managed = out:FindFirstChild("_NetManaged")
                        if managed then
                            local remote = managed:FindFirstChild("CLIENT_HARVEST_CROP_REQUEST")
                            if remote then return remote end
                        end
                    end
                end
            end
        end
    end
    
    -- Search all
    local function search(parent, name)
        for _, child in ipairs(parent:GetChildren()) do
            if child.Name == name then return child end
            local found = search(child, name)
            if found then return found end
        end
        return nil
    end
    
    return search(rs, "CLIENT_HARVEST_CROP_REQUEST")
end

-- Capture the offset from manual harvest
local function startCaptureMode()
    if captureMode then
        statusLabel.Text = "Status: Already in capture mode! Go harvest a berry bush."
        return
    end
    
    harvestRemote = findHarvestRemote()
    if not harvestRemote then
        statusLabel.Text = "Status: ERROR - Cannot find harvest remote!"
        return
    end
    
    -- Hook the remote to capture the offset
    local oldInvoke = harvestRemote.InvokeServer
    
    harvestRemote.InvokeServer = function(self, data)
        -- Capture the offset from the manual harvest
        if data and data["dZnpyRtxna"] then
            capturedOffset = data["dZnpyRtxna"]
            
            -- Show the captured offset
            local display = capturedOffset:gsub("[%z%c]", function(c)
                return string.format("\\x%02X", string.byte(c))
            end)
            offsetLabel.Text = "Captured Offset: " .. display .. "\n✓ Ready to auto harvest!"
            statusLabel.Text = "Status: ✓ OFFSET CAPTURED! You can now auto harvest."
            
            captureMode = false
            
            -- Restore original function
            harvestRemote.InvokeServer = oldInvoke
            
            print("=== OFFSET CAPTURED ===")
            print(capturedOffset)
            print("======================")
        end
        
        -- Call original
        return oldInvoke(self, data)
    end
    
    captureMode = true
    statusLabel.Text = "Status: CAPTURE MODE ACTIVE - Now manually harvest ONE berry bush!"
    offsetLabel.Text = "Captured Offset: WAITING FOR MANUAL HARVEST...\nGo pick a berry bush right now!"
end

-- Reset captured offset
local function resetOffset()
    capturedOffset = nil
    captureMode = false
    offsetLabel.Text = "Captured Offset: NOT YET CAPTURED\nClick 'START LEARNING' then manually harvest!"
    statusLabel.Text = "Status: Offset reset. Click START LEARNING to capture new offset."
end

-- Calculate distance
local function getDistance(pos1, pos2)
    return (pos1 - pos2).Magnitude
end

-- Get block position safely
local function getBlockPos(block)
    if block:IsA("BasePart") then
        return block.Position
    end
    local posPart = block:FindFirstChild("Position")
    if posPart and posPart:IsA("BasePart") then
        return posPart.Position
    end
    return Vector3.new(0, 0, 0)
end

-- Find all harvestable objects
local function findHarvestableObjects()
    statusLabel.Text = "Status: Scanning for berry bushes/crops..."
    harvestableObjects = {}
    
    local player = game:GetService("Players").LocalPlayer
    local char = player.Character
    local playerPos = char and char.PrimaryPart and char.PrimaryPart.Position or Vector3.new(0, 0, 0)
    
    local islands = workspace:FindFirstChild("Islands")
    if not islands then
        listBox.Text = "No Islands found!"
        return
    end
    
    for _, island in ipairs(islands:GetChildren()) do
        local blocks = island:FindFirstChild("Blocks")
        if blocks then
            for _, block in ipairs(blocks:GetChildren()) do
                local name = safeString(block.Name):lower()
                local isHarvestable = false
                
                -- Look for berry bushes and crops
                if name:find("berry") or name:find("bush") then
                    isHarvestable = true
                elseif name:find("crop") or name:find("wheat") or name:find("carrot") or name:find("potato") then
                    isHarvestable = true
                elseif name:find("tomato") or name:find("pumpkin") then
                    isHarvestable = true
                elseif block:FindFirstChild("Health") then
                    isHarvestable = true
                end
                
                if isHarvestable then
                    local pos = getBlockPos(block)
                    local dist = getDistance(playerPos, pos)
                    
                    table.insert(harvestableObjects, {
                        name = safeString(block.Name),
                        model = block,
                        position = pos,
                        distance = dist
                    })
                end
            end
        end
    end
    
    -- Sort by closest first
    table.sort(harvestableObjects, function(a, b) return a.distance < b.distance end)
    
    -- Update display
    local text = "Found " .. #harvestableObjects .. " harvestable objects (closest first):\n\n"
    for i, obj in ipairs(harvestableObjects) do
        text = text .. string.format("%d. %s - %.0f studs\n", i, obj.name, obj.distance)
        if i >= 20 then
            text = text .. "\n... and " .. (#harvestableObjects - 20) .. " more"
            break
        end
    end
    
    listBox.Text = text
    statusLabel.Text = "Status: Found " .. #harvestableObjects .. " objects"
end

-- Harvest an object
local function harvestObject(obj)
    if not capturedOffset then
        statusLabel.Text = "Status: No offset! Click START LEARNING and manually harvest first!"
        return false
    end
    
    if not obj or not obj.model then
        return false
    end
    
    local remote = findHarvestRemote()
    if not remote then
        statusLabel.Text = "Status: Cannot find harvest remote!"
        return false
    end
    
    statusLabel.Text = "Status: Harvesting " .. obj.name
    
    local success, err = pcall(function()
        return remote:InvokeServer({
            ["dZnpyRtxna"] = capturedOffset,
            ["player"] = game:GetService("Players").LocalPlayer,
            ["model"] = obj.model,
        })
    end)
    
    if success then
        statusLabel.Text = "Status: ✓ Harvested " .. obj.name
        return true
    else
        statusLabel.Text = "Status: Failed - " .. safeString(err)
        return false
    end
end

-- Harvest closest
local function harvestClosest()
    if not capturedOffset then
        statusLabel.Text = "Status: No offset! Click START LEARNING and manually harvest first!"
        return
    end
    
    if #harvestableObjects == 0 then
        findHarvestableObjects()
    end
    
    if #harvestableObjects == 0 then
        statusLabel.Text = "Status: No objects found nearby!"
        return
    end
    
    -- Update distances
    local player = game:GetService("Players").LocalPlayer
    local char = player.Character
    local playerPos = char and char.PrimaryPart and char.PrimaryPart.Position or Vector3.new(0, 0, 0)
    
    for _, obj in ipairs(harvestableObjects) do
        if obj.model and obj.model.Parent then
            obj.distance = getDistance(playerPos, obj.position)
        end
    end
    
    table.sort(harvestableObjects, function(a, b) return a.distance < b.distance end)
    
    local closest = harvestableObjects[1]
    if closest then
        harvestObject(closest)
        task.wait(0.5)
        findHarvestableObjects() -- Refresh list
    end
end

-- Harvest all (closest first with 0.01s wait)
local function harvestAll()
    if not capturedOffset then
        statusLabel.Text = "Status: No offset! Click START LEARNING and manually harvest first!"
        return
    end
    
    if #harvestableObjects == 0 then
        findHarvestableObjects()
    end
    
    if #harvestableObjects == 0 then
        statusLabel.Text = "Status: No objects found!"
        return
    end
    
    -- Update and sort all distances
    local player = game:GetService("Players").LocalPlayer
    local char = player.Character
    local playerPos = char and char.PrimaryPart and char.PrimaryPart.Position or Vector3.new(0, 0, 0)
    
    for _, obj in ipairs(harvestableObjects) do
        if obj.model and obj.model.Parent then
            obj.distance = getDistance(playerPos, obj.position)
        end
    end
    
    table.sort(harvestableObjects, function(a, b) return a.distance < b.distance end)
    
    statusLabel.Text = "Status: Harvesting " .. #harvestableObjects .. " objects (closest first)..."
    
    local count = 0
    for _, obj in ipairs(harvestableObjects) do
        if obj.model and obj.model.Parent then
            if harvestObject(obj) then
                count = count + 1
            end
            task.wait(0.01) -- 0.01 second wait between harvests
        end
    end
    
    statusLabel.Text = string.format("Status: Done! Harvested %d/%d objects", count, #harvestableObjects)
    task.wait(1)
    findHarvestableObjects()
end

