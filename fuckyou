		endMarker = createMarker(END_MARKER_NAME, Color3.fromRGB(255, 95, 95))
		endMarker.CFrame = clickedBlock.CFrame
		notify("Selection", "End corner picked.", 2)
	end

	selectionPickMode = nil

	if selectionStartBlock and selectionEndBlock then
		rebuildSelectionPart()
