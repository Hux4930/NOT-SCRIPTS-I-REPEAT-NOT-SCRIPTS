	Description = "",
	Callback = function()
		if pasteInProgress then
			notify("Preview", "Stop the paste first.", 3)
			return
		end

		clearPreview()
	end
})

local function pastePreview()
	if pasteInProgress then
		notify("Paste", "A paste is already running.", 3)
		return
	end

	local previewBlocks = getPreviewBlocks()
	if #previewBlocks == 0 then
		notify("Paste", "Load or copy a preview first.", 3)
		return
	end

	local ok, err = resolvePlacementHash(false)
	if not ok then
		notify("Paste", tostring(err), 5)
		return
	end

	pasteInProgress = true

	task.spawn(function()
		local pending = {}
		for _, block in ipairs(previewBlocks) do
			table.insert(pending, block)
		end

		local total = #pending
		local placed = 0
		local noProgressLoops = 0

		while pasteInProgress and #pending > 0 do
			local humanoidRootPart = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
			if not humanoidRootPart then
				task.wait(0.5)
				continue
			end

			local didPlace = false

			for index = #pending, 1, -1 do
				local previewBlock = pending[index]
				if not previewBlock or not previewBlock.Parent then
					table.remove(pending, index)
				else
					local distance = (previewBlock.Position - humanoidRootPart.Position).Magnitude
					if distance <= 50 then
						local success = placeBlockRequest(previewBlock.CFrame, previewBlock.Name)
						if success then
							placed = placed + 1
							didPlace = true
							previewBlock:Destroy()
							table.remove(pending, index)
						end
					end
				end
			end

			if didPlace then
				noProgressLoops = 0
				updatePreviewStatus()
				task.wait(0.15)
			else
				noProgressLoops = noProgressLoops + 1
				if noProgressLoops >= 10 then
					notify("Paste", "Move closer to the preview so more blocks are in range.", 4)
					noProgressLoops = 0
				end
				task.wait(0.75)
			end
		end

		local wasStopped = not pasteInProgress
		pasteInProgress = false
		updatePreviewStatus()

		if wasStopped then
			notify("Paste", string.format("Paste stopped after placing %d of %d blocks.", placed, total), 4)
		else
			notify("Paste", string.format("Finished placing %d blocks.", placed), 4)
		end
	end)
end

PasteSection:AddButton({
	Title = "Paste Preview",
	Description = "",
	Callback = function()
		pastePreview()
	end
})

PasteSection:AddButton({
