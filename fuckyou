local function updateSelectionStatus()
	if not selectionStartBlock or not selectionEndBlock then
		SelectionStatus:SetDesc("pick a start and end block")
		return
	end

	local minX = math.min(selectionStartBlock.Position.X, selectionEndBlock.Position.X)
	local minY = math.min(selectionStartBlock.Position.Y, selectionEndBlock.Position.Y)
	local minZ = math.min(selectionStartBlock.Position.Z, selectionEndBlock.Position.Z)
	local maxX = math.max(selectionStartBlock.Position.X, selectionEndBlock.Position.X)
	local maxY = math.max(selectionStartBlock.Position.Y, selectionEndBlock.Position.Y)
	local maxZ = math.max(selectionStartBlock.Position.Z, selectionEndBlock.Position.Z)

	local sizeX = ((maxX - minX) / BLOCK_SIZE) + 1
	local sizeY = ((maxY - minY) / BLOCK_SIZE) + 1
	local sizeZ = ((maxZ - minZ) / BLOCK_SIZE) + 1
	local totalCells = sizeX * sizeY * sizeZ

	SelectionStatus:SetDesc(string.format("%dx%dx%d selection (%d grid cells)", sizeX, sizeY, sizeZ, totalCells))
end

local function rebuildSelectionPart()
	if not selectionStartBlock or not selectionEndBlock then
		return
	end

	local minX = math.min(selectionStartBlock.Position.X, selectionEndBlock.Position.X)
	local minY = math.min(selectionStartBlock.Position.Y, selectionEndBlock.Position.Y)
	local minZ = math.min(selectionStartBlock.Position.Z, selectionEndBlock.Position.Z)
	local maxX = math.max(selectionStartBlock.Position.X, selectionEndBlock.Position.X)
	local maxY = math.max(selectionStartBlock.Position.Y, selectionEndBlock.Position.Y)
	local maxZ = math.max(selectionStartBlock.Position.Z, selectionEndBlock.Position.Z)

	local size = Vector3.new(
		(maxX - minX) + BLOCK_SIZE,
		(maxY - minY) + BLOCK_SIZE,
		(maxZ - minZ) + BLOCK_SIZE
	)

	local center = Vector3.new(
		(minX + maxX) / 2,
		(minY + maxY) / 2,
		(minZ + maxZ) / 2
	)

	if not selectionPart then
		selectionPart = Instance.new("Part")
		selectionPart.Name = SELECTION_PART_NAME
		selectionPart.Anchored = true
		selectionPart.CanCollide = false
		selectionPart.CastShadow = false
		selectionPart.Material = Enum.Material.Neon
		selectionPart.Color = Color3.fromRGB(75, 170, 255)
		selectionPart.Transparency = 0.8
		selectionPart.Parent = Workspace

		local box = Instance.new("SelectionBox")
		box.LineThickness = 0.05
		box.Color3 = Color3.fromRGB(75, 170, 255)
		box.SurfaceTransparency = 1
		box.Adornee = selectionPart
		box.Parent = selectionPart
	end

	selectionPart.Size = size
	selectionPart.CFrame = CFrame.new(center)
	updateSelectionStatus()
end

