local function buildLocalOffset(xBlocks, yBlocks, zBlocks)
	local xStuds = (tonumber(xBlocks) or 0) * BLOCK_SIZE
	local yStuds = (tonumber(yBlocks) or 0) * BLOCK_SIZE
	local zStuds = (tonumber(zBlocks) or 0) * BLOCK_SIZE

	local primary = ensurePreviewPrimaryPart()
	if not primary then
		return Vector3.new(xStuds, yStuds, zStuds)
	end

	return (primary.CFrame.RightVector * xStuds)
		+ (primary.CFrame.UpVector * yStuds)
		+ (primary.CFrame.LookVector * zStuds)
end

local function movePreviewByBlocks(xBlocks, yBlocks, zBlocks)
	local primary = ensurePreviewPrimaryPart()
	if not primary then
		notify("Preview", "Load or copy a preview first.", 3)
		return false
	end

	cloneFolder:SetPrimaryPartCFrame(primary.CFrame + buildLocalOffset(xBlocks, yBlocks, zBlocks))
	return true
end

local function getSelectionBlocks()
