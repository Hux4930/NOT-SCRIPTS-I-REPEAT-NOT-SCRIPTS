local function ensureJsonExtension(name)
	name = tostring(name or ""):gsub("^%s+", ""):gsub("%s+$", "")
	if name == "" then
		name = "Template"
	end
	if not name:lower():match("%.json$") then
		name = name .. ".json"
	end
	return name
end

