        if netManaged then netManaged = netManaged.node_modules:FindFirstChild("@rbxts").net.out._NetManaged; if netManaged and netManaged:FindFirstChild("CLIENT_VISIT_ISLAND_REQUEST") then netManaged.CLIENT_VISIT_ISLAND_REQUEST:InvokeServer(unpack({ [1] = { ["island"] = island } })) end end
    end
end)
SecTeleport:AddButton("Hub", function()
    local Portal = nil; local island = GetMyIsland()
    if island and island:FindFirstChild("Blocks") then
        for _, v in pairs(island.Blocks:GetChildren()) do if v:FindFirstChild("PortalActive") and v:FindFirstChild("portal-to-spawn") then Portal = v; break end end 
    end
    if Portal then local cb = Portal:FindFirstChild("CollisionBoxes"); if cb and cb:FindFirstChild("Part") then DoTeleport(cb.Part.CFrame) end else
        local Portal2 = workspace:FindFirstChild("portalToSpawn", true); if Portal2 then local cb = Portal2:FindFirstChild("CollisionBoxes"); if cb and cb:FindFirstChild("Part") then DoTeleport(cb.Part.CFrame) end end
