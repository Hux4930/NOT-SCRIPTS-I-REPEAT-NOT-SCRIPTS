local function SaveConfig(name)
    if not name or name == "" then name = "Default" end
    local data = { rainbowEnabled = rainbowThemeEnabled, rainbowSpeed = getgenv().rainbowSpeed, pixelAnimEnabled = getgenv().pixelAnimEnabled, slideFromLeftEnabled = slideFromLeft, unlockChatEnabled = unlockChatEnabled, antiAfkEnabled = getgenv().antiAfkEnabled }
    if writefile then
        if not isfolder(ConfigFolder) then pcall(function() makefolder(ConfigFolder) end) end
        local success, err = pcall(function() writefile(ConfigFolder .. "/" .. name .. ".json", HttpService:JSONEncode(data)) end)
        if success then SwizUI:Notify("Config Saved", "Successfully saved config: " .. name) else SwizUI:Notify("Error", "Failed to save config: " .. tostring(err)) end
    end
end
local function LoadSpecificConfig(name)
    local filePath = ConfigFolder .. "/" .. name .. ".json"
    if readfile and isfile and isfile(filePath) then
        local readSuccess, rawData = pcall(function() return readfile(filePath) end)
        if readSuccess and rawData then
            local jsonSuccess, data = pcall(function() return HttpService:JSONDecode(rawData) end)
            if jsonSuccess and data then
                if data.rainbowEnabled ~= nil and SwizUI.Toggles.Rainbow then SwizUI.Toggles.Rainbow:Set(data.rainbowEnabled) end
                if data.rainbowSpeed ~= nil and SwizUI.Sliders.RainbowSpeed then SwizUI.Sliders.RainbowSpeed:Set(data.rainbowSpeed) end
                if data.pixelAnimEnabled ~= nil and SwizUI.Toggles.PixelAnim then SwizUI.Toggles.PixelAnim:Set(data.pixelAnimEnabled) end
                if data.slideFromLeftEnabled ~= nil and SwizUI.Toggles.SlideMenu then SwizUI.Toggles.SlideMenu:Set(data.slideFromLeftEnabled) end
                if data.unlockChatEnabled ~= nil and SwizUI.Toggles.UnlockChat then SwizUI.Toggles.UnlockChat:Set(data.unlockChatEnabled) end
                if data.antiAfkEnabled ~= nil and SwizUI.Toggles.AntiAfk then SwizUI.Toggles.AntiAfk:Set(data.antiAfkEnabled) end
                SwizUI:Notify("Config Loaded", "Loaded settings from: " .. name)
                if ActiveConfigLbl then ActiveConfigLbl.Text = "Active Config: " .. name end
            end
        end
    end
end
local function DeleteConfig(name)
    local filePath = ConfigFolder .. "/" .. name .. ".json"
    if isfile and isfile(filePath) and delfile then pcall(function() delfile(filePath) end); SwizUI:Notify("Config Deleted", "Removed config: " .. name) end
end
local function GetConfigFiles()
    local files = {}
    if listfiles then
        if not isfolder(ConfigFolder) then pcall(function() makefolder(ConfigFolder) end) end
        pcall(function()
            for _, file in ipairs(listfiles(ConfigFolder)) do
                if string_find(file, "%.json") then
                    local splitPath = string_split(string_gsub(file, "\\", "/"), "/")
                    local fileName = splitPath[#splitPath]
                    local name = string_gsub(fileName, "%.json", "")
                    if name then table_insert(files, name) end
                end
            end
        end)
    end
    return files
end

