                            if not getgenv().MobHitKey then
                                getgenv().MobHitKey = k; getgenv().MobHitValue = v; getgenv().MobHitRemoteName = rName
                            end
                            getgenv().MobHitKey = k; getgenv().MobHitValue = v; getgenv().MobHitRemoteName = rName
