local TabTeleport = Window:AddTab("Teleport")
local SecTeleport = TabTeleport:AddSection("Locations")
getgenv().TeleportMethod = "Instant"; getgenv().TweenSpeed = 50; local currentTween = nil
local function StopTeleport() if currentTween then currentTween:Cancel(); currentTween = nil; SwizUI:Notify("Teleport", "Tween movement stopped.") end end
local function DoTeleport(targetCFrame)
    local char = lp.Character; local hrp = char and char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
    if currentTween then currentTween:Cancel(); currentTween = nil end
    if getgenv().TeleportMethod == "Tween" then
        local dist = (hrp.Position - targetCFrame.Position).Magnitude; local ti = TweenInfo.new(dist / getgenv().TweenSpeed, Enum.EasingStyle.Linear)
        currentTween = TweenService:Create(hrp, ti, {CFrame = targetCFrame}); currentTween:Play()
    else hrp.CFrame = targetCFrame end
end
SecTeleport:AddToggle("Use Tween Teleport", false, function(state) getgenv().TeleportMethod = state and "Tween" or "Instant" end)
