function StartOreAura()
    task_spawn(function()
        while toggleStates.OreAura do
            local char = lp.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")

            if not hrp then task_wait(1); continue end

            if not getgenv().HitAuraKey then
                SwizUI:Notify("Waiting", "Hit an ore manually once to bypass!")
                task_wait(3); continue
            end

            local pickaxe = GetEquippedTool()
            if not pickaxe then task_wait(1); continue end

            -- Rescan every cycle (fast, no caching delay)
            local ores = {}
            local containers = GetFarmContainers()

            for _, container in ipairs(containers) do
                local children = container:GetChildren()
                for i = 1, #children do
                    local block = children[i]
                    if IsAuraOreMatch(block) then
                        local hitPart = block:FindFirstChild("1") or block:FindFirstChildWhichIsA("BasePart")
                        if hitPart and hitPart:IsA("BasePart") then
                            table_insert(ores, {
                                block = block,
                                part = hitPart,
                                dist = (hrp.Position - hitPart.Position).Magnitude
                            })
                        end
                    end
                end
            end

            table_sort(ores, function(a, b) return a.dist < b.dist end)

            if #ores == 0 then task_wait(0.1); continue end

            local closest = ores[1]
            if not closest.block.Parent then continue end

            local closestDist = (hrp.Position - closest.part.Position).Magnitude

            if closestDist <= 15 then
                -- Mine all ores within 15 studs
                local netManaged = ReplicatedStorage:FindFirstChild("rbxts_include")
                if netManaged then
                    netManaged = netManaged.node_modules:FindFirstChild("@rbxts").net.out._NetManaged
                    local blockRemote = netManaged and netManaged:FindFirstChild(BlockHitRemoteName)

                    if blockRemote then
                        for _, ore in ipairs(ores) do
                            if ore.block and ore.block.Parent and ore.part and ore.part.Parent then
                                if (hrp.Position - ore.part.Position).Magnitude <= 15 then
                                    pcall(function()
                                        blockRemote:InvokeServer({
                                            [getgenv().HitAuraKey] = getgenv().HitAuraValue,
                                            ["part"]  = ore.part,
                                            ["block"] = ore.block,
                                            ["norm"]  = ore.part.Position,
                                            ["pos"]   = Vector3.new(
                                                math_random(-100, 100) / 100,
                                                math_random(0,   100) / 100,
                                                math_random(-100, 100) / 100
                                            )
                                        })
                                    end)
                                    task_wait(0.03)
                                end
                            end
                        end
                    end
                end
                -- Loop immediately — no extra wait

            else
                -- Tween to closest ore
                local hrp2 = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                if hrp2 and closest.part.Parent then
                    local targetCFrame = CFrame.new(closest.part.Position + Vector3.new(0, 3, 0))
                    local duration = math.max((hrp2.Position - targetCFrame.Position).Magnitude / 35, 0.05)
                    local moveTween = TweenService:Create(hrp2, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
                    moveTween:Play()
                    moveTween.Completed:Wait()
                end
                -- Loop immediately after tween — rescan and mine
            end
        end
    end)
end
