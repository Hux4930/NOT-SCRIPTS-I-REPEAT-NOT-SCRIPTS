                            end
                            getgenv().HarvestKey = k; getgenv().HarvestValue = v
                        end
                    end
                elseif string_find(rName, "PLACE") then
                    for k, v in pairs(args[1]) do
                        if type(k) == "string" and not ignorePlaceKeys[k] then
                            if not getgenv().PlantKey then getgenv().PlantKey = k; getgenv().PlantValue = v end
                            getgenv().PlantKey = k; getgenv().PlantValue = v
                        end
                    end
                end
            end
        elseif method == "FireServer" then
             local rName = tostring(self)
            local args = {...}
            if type(args[1]) == "string" and type(args[2]) == "table" and type(args[2][1]) == "table" then
                if args[2][1]["hitUnit"] then
                    for k, v in pairs(args[2][1]) do
