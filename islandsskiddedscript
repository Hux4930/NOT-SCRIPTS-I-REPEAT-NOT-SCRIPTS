local function GetFarmContainers()
    local containers = {}
    if workspace:FindFirstChild("WildernessBlocks") then table_insert(containers, workspace.WildernessBlocks) end
    local islands = workspace:FindFirstChild("Islands")
    if islands then
        local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            for _, island in ipairs(islands:GetChildren()) do
                local islandPos = island:GetPivot().Position
                if (hrp.Position - islandPos).Magnitude <= 1000 then
                    local blocks = island:FindFirstChild("Blocks"); if blocks then table_insert(containers, blocks) end
                end
            end
        end
    end
    return containers
end

local function UpdateESP()
    local anyEspOn = getgenv().OreEspTextEnabled or getgenv().OreEspHighlightEnabled or getgenv().TreeEspTextEnabled or getgenv().TreeEspHighlightEnabled or getgenv().CropEspTextEnabled or getgenv().CropEspHighlightEnabled
    local char = lp.Character; local hrp = char and char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
    local currentBlocks = {}
    
    if anyEspOn then
        local containers = GetFarmContainers(); local blocksInRadius = {}
        for _, container in ipairs(containers) do
            for i, block in ipairs(container:GetChildren()) do
                if i % 100 == 0 then task_wait() end
                local isOre = IsEspOreMatch(block); local isTree = IsEspTreeMatch(block); local isCrop = IsEspCropMatch(block)
                if isOre or isTree or isCrop then
                    local hitPart = block:FindFirstChild("trunk") or block:FindFirstChild("1") or block:FindFirstChildWhichIsA("MeshPart") or block:FindFirstChildWhichIsA("BasePart")
                    if hitPart and (hitPart:IsA("BasePart") or hitPart:IsA("MeshPart")) then
                        local dist = (hrp.Position - hitPart.Position).Magnitude
                        local maxDist = (isCrop) and 1000 or 150
                        if dist <= maxDist then table_insert(blocksInRadius, {block = block, part = hitPart, dist = dist, isOre = isOre, isTree = isTree, isCrop = isCrop}) end
                    end
                end
            end
        end
        table_sort(blocksInRadius, function(a, b) return a.dist < b.dist end)
        local highlightCount = 0
        
        for _, data in ipairs(blocksInRadius) do
             local block = data.block; local hitPart = data.part; local isOre = data.isOre; local isTree = data.isTree; local isCrop = data.isCrop
            currentBlocks[block] = hitPart
            local textEnabled = (isOre and getgenv().OreEspTextEnabled) or (isTree and getgenv().TreeEspTextEnabled) or (isCrop and getgenv().CropEspTextEnabled)
            local hlEnabled = (isOre and getgenv().OreEspHighlightEnabled) or (isTree and getgenv().TreeEspHighlightEnabled) or (isCrop and getgenv().CropEspHighlightEnabled)
            
            local espColor = Color3.fromRGB(255, 255, 255)
            if isOre then espColor = Color3.fromRGB(0, 255, 127) elseif isTree then espColor = Color3.fromRGB(255, 170, 0) elseif isCrop then espColor = Color3.fromRGB(255, 85, 255) end
            
            if textEnabled then
                if not espCache[block] then
                    local esp = Instance.new("BillboardGui"); esp.Name = "FarmESP_Text"; esp.Adornee = hitPart; esp.Size = UDim2.new(0, 100, 0, 25)
                    esp.StudsOffset = Vector3.new(0, 2, 0); esp.AlwaysOnTop = true; esp.MaxDistance = 1000
                    local txt = Instance.new("TextLabel", esp); txt.Size = UDim2.new(1, 0, 1, 0); txt.BackgroundTransparency = 1
                    local displayName = block.Name; if isOre then displayName = string_gsub(displayName, "rock", ""); if displayName == "" then displayName = "Rock" end end
                    txt.Text = displayName; txt.TextColor3 = espColor; txt.TextStrokeTransparency = 0.5; txt.Font = Enum.Font.GothamBold; txt.TextSize = 12
                    esp.Parent = espFolder; espCache[block] = esp
                else espCache[block].Enabled = true end
            else if espCache[block] then espCache[block].Enabled = false end end
            
            if hlEnabled and highlightCount < 25 then
                highlightCount = highlightCount + 1
                if not highlightCache[block] then
                    local hl = Instance.new("Highlight"); hl.Name = "FarmESP_HL"; hl.Adornee = hitPart; hl.FillColor = espColor; hl.FillTransparency = 0.4
                    hl.OutlineColor = Color3.fromRGB(255, 255, 255); hl.OutlineTransparency = 0; hl.Parent = espFolder; highlightCache[block] = hl
                else highlightCache[block].Enabled = true end
            else if highlightCache[block] then highlightCache[block].Enabled = false end end
        end
    end
    
    for block, esp in pairs(espCache) do
        if not block.Parent then esp:Destroy(); espCache[block] = nil elseif not currentBlocks[block] or not anyEspOn then esp.Enabled = false end
    end
    for block, hl in pairs(highlightCache) do
        if not block.Parent then hl:Destroy(); highlightCache[block] = nil elseif not currentBlocks[block] or not anyEspOn then hl.Enabled = false end
    end
end
task_spawn(function() while true do pcall(function() UpdateESP() end); task_wait(1) end end)

