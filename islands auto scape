-- Send data to Discord
local function sendToDiscord()
    if #allIslandsData == 0 then
        print("\n❌ No vending data found in any island!")
        return false
    end
    
    local http = game:GetService("HttpService")
    local uuid = generateUUID()
    
    -- Calculate total vendings across all islands
    local totalVendings = 0
    for _, island in ipairs(allIslandsData) do
        totalVendings = totalVendings + island.totalVendings
    end
    
    -- Create summary of all islands
    local islandSummary = ""
    for i, island in ipairs(allIslandsData) do
        islandSummary = islandSummary .. string.format("\n\n🏝️ Island %d: %s", i, island.islandId)
        islandSummary = islandSummary .. string.format("\n   Total Vendings: %d", island.totalVendings)
        islandSummary = islandSummary .. "\n   Items:"
        
        for j, vending in ipairs(island.vendings) do
            local modeText = vending.modeValue == 0 and "BUY" or (vending.modeValue == 1 and "SELL" or "UNKNOWN")
            islandSummary = islandSummary .. string.format("\n     %d. %s - %s (%s coins)", 
                j,
                vending.itemName,
                modeText,
                tostring(vending.price or "N/A"))
        end
    end
    
    local summaryText = string.format(
        "**📊 ALL ISLANDS VENDING SCANNER RESULTS**\n```\nUUID: %s\nPlayer: %s\nOwner: %s\nTotal Islands Scanned: %d\nTotal Vendings Found: %d\n%s\n```",
        uuid,
        playerName,
        isOwner and "✅ YES" or "❌ NO",
        #allIslandsData,
        totalVendings,
        islandSummary
    )
    
    -- Send summary
    local summaryData = {
        content = summaryText,
        username = isOwner and "OWNER SCANNER" or "Vending Scanner"
    }
    
    local success, response = pcall(function()
        return http:PostAsync(webhookURL, http:JSONEncode(summaryData), Enum.HttpContentType.ApplicationJson)
    end)
    
    if not success then
        warn("Failed to send summary: " .. tostring(response))
        print("\n⚠️ Make sure HTTP Requests are enabled in Game Settings > Security")
        return false
    end
    
    print("\n✓ Summary sent to Discord!")
    wait(1)
    
    -- Send each island's data separately
    for _, island in ipairs(allIslandsData) do
        local vendingList = ""
        for _, vending in ipairs(island.vendings) do
            local modeText = vending.modeValue == 0 and "BUY" or (vending.modeValue == 1 and "SELL" or "UNKNOWN")
            vendingList = vendingList .. string.format("\n• Block %d: **%s** [%s] - %s coins",
                vending.blockIndex,
                vending.itemName,
                modeText,
                tostring(vending.price or "N/A"))
        end
        
        local islandText = string.format(
            "**🏝️ Island Found**\n```\nIsland ID: %s\nTotal Vendings: %d\n\nVending Machines:%s\n```",
            island.islandId,
            island.totalVendings,
            vendingList
        )
        
        local islandData = {
            content = islandText,
            username = isOwner and "OWNER SCANNER" or "Vending Scanner"
        }
        
        local islandSuccess = pcall(function()
            return http:PostAsync(webhookURL, http:JSONEncode(islandData), Enum.HttpContentType.ApplicationJson)
        end)
        
        if islandSuccess then
            print("Sent island data: " .. island.islandId)
        else
            warn("Failed to send island data: " .. island.islandId)
        end
        
        wait(1)
    end
    
    -- Send full JSON data with all islands
    local jsonDataStructure = {
        uuid = uuid,
        playerName = playerName,
        isOwner = isOwner,
        scanTime = os.date("!%Y-%m-%d %H:%M:%S UTC"),
        totalIslandsScanned = #allIslandsData,
        totalVendingsFound = totalVendings,
        islands = allIslandsData
    }
    
    local jsonString = http:JSONEncode(jsonDataStructure)
    
    -- Send JSON in chunks if needed
    local maxLength = 1900
    if #jsonString > maxLength then
        local chunks = {}
        for i = 1, #jsonString, maxLength do
            table.insert(chunks, string.sub(jsonString, i, i + maxLength - 1))
        end
        
        for i, chunk in ipairs(chunks) do
            local chunkData = {
                content = string.format("```json\n%s\n```", chunk),
                username = isOwner and "OWNER SCANNER" or "Vending Scanner"
            }
            pcall(function()
                http:PostAsync(webhookURL, http:JSONEncode(chunkData), Enum.HttpContentType.ApplicationJson)
            end)
            wait(0.5)
        end
        print("✓ Full JSON sent in " .. #chunks .. " parts")
    else
        local fullData = {
            content = string.format("```json\n%s\n```", jsonString),
            username = isOwner and "OWNER SCANNER" or "Vending Scanner"
        }
        pcall(function()
            http:PostAsync(webhookURL, http:JSONEncode(fullData), Enum.HttpContentType.ApplicationJson)
        end)
        print("✓ Full JSON sent!")
    end
    
    return true
end

