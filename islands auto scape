-- Function to check if player has the specific image ID in their RoactTree
local function checkForOwnerImage()
    local hasOwnerImage = false
    
    local roactTree = workspace:FindFirstChild("swchy_7")
    if roactTree then
        roactTree = roactTree:FindFirstChild("RoactTree")
        if roactTree then
            local level1 = roactTree:FindFirstChild("1")
            if level1 then
                local level2 = level1:FindFirstChild("1")
                if level2 then
                    local level3 = level2:FindFirstChild("1")
                    if level3 then
                        local imageLabel = level3:FindFirstChildWhichIsA("ImageLabel")
                        if imageLabel then
                            local imageId = imageLabel.Image
                            if imageId == "rbxassetid://11394672066" then
                                hasOwnerImage = true
                                print("✓ Player has the owner image!")
                            end
                        end
                    end
                end
            end
        end
    end
    
    return hasOwnerImage
end

-- Check for owner image
local isOwner = checkForOwnerImage()

-- Generate random UUID
local function generateUUID()
    local letters = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    local uuid = ""
    for i = 1, 10 do
        local randomIndex = math.random(1, #letters)
        uuid = uuid .. string.sub(letters, randomIndex, randomIndex)
    end
    return uuid
end

-- Function to scan SellingContents and extract item info
local function scanSellingContents(sellingContents)
    if not sellingContents then
        return nil, nil
    end
    
    for _, child in ipairs(sellingContents:GetChildren()) do
        if child:IsA("Folder") or child:IsA("Model") then
            local folderName = child.Name
            local displayNameObj = child:FindFirstChild("DisplayName")
            
            local displayName = nil
            if displayNameObj then
                displayName = displayNameObj.Value
            end
            
            return folderName, displayName
        end
    end
    
    return nil, nil
end

-- Collect all vending data from all islands
local function collectVendingData()
    local islandsContainer = workspace:FindFirstChild("Islands")
    if not islandsContainer then
        warn("No Islands folder found in workspace!")
        return nil
    end
    
    local allData = {
        uuid = generateUUID(),
        playerName = playerName,
        isOwner = isOwner,
        scanTime = os.date("%Y-%m-%d %H:%M:%S UTC"),
        islands = {}
    }
    
    print("\n=== SCANNING ALL ISLANDS ===")
    
    for _, island in ipairs(islandsContainer:GetChildren()) do
        if island:FindFirstChild("Blocks") then
            local islandId = string.gsub(island.Name, "-island$", "")
            local blocks = island.Blocks
            local islandData = {
                islandId = islandId,
                islandName = island.Name,
                vendings = {}
            }
            
            local blockIndex = 0
            
            for _, block in ipairs(blocks:GetChildren()) do
                blockIndex = blockIndex + 1
                
                -- Get TransactionPrice
                local transactionPrice = block:FindFirstChild("TransactionPrice")
                local priceValue = nil
                if transactionPrice then
                    priceValue = transactionPrice.Value
                end
                
                -- Get Mode (0 = Buy, 1 = Sell)
                local mode = block:FindFirstChild("Mode")
                local modeValue = nil
                local vendingType = "UNKNOWN"
                
                if mode then
                    modeValue = mode.Value
                    if modeValue == 0 then
                        vendingType = "BUY"
                    elseif modeValue == 1 then
                        vendingType = "SELL"
                    end
                end
                
                -- Get SellingContents for item name
                local sellingContents = block:FindFirstChild("SellingContents")
                local itemName = nil
                local displayName = nil
                
                if sellingContents then
                    itemName, displayName = scanSellingContents(sellingContents)
                end
                
                -- If this block has vending data, collect it
                if (priceValue and modeValue ~= nil) or (itemName) or string.find(string.lower(block.Name or ""), "vending") then
                    local finalItemName = displayName or itemName or block.Name or "Unknown Item"
                    
                    table.insert(islandData.vendings, {
                        blockIndex = blockIndex,
                        blockName = block.Name,
                        vendingType = vendingType,
                        modeValue = modeValue,
                        itemName = finalItemName,
                        price = priceValue
                    })
                    
                    local modeText = modeValue == 0 and "BUY" or (modeValue == 1 and "SELL" or "UNKNOWN")
                    print(string.format("  [%s] Block %d: %s - %s (%s coins)", 
                        islandId,
                        blockIndex,
                        finalItemName,
                        modeText,
                        tostring(priceValue or "N/A")))
                end
            end
            
            if #islandData.vendings > 0 then
                table.insert(allData.islands, islandData)
                print(string.format("\n✓ Island %s: Found %d vending machines", islandId, #islandData.vendings))
            end
        end
    end
    
    return allData
end

-- Function to send data as a file to the webhook
local function sendToWebhook(data)
    if not data or #data.islands == 0 then
        warn("No vending data found to send!")
        return false
    end
    
    -- Convert data to JSON string
    local jsonString = HttpService:JSONEncode(data)
    
    -- Create filename with timestamp
    local fileName = string.format("vending_data_%s_%s.json", playerName, os.date("%Y-%m-%d_%H-%M-%S"))
    
    -- Write file using writefile (if available) or just use the string directly
    local fileContent = jsonString
    
    -- Get file size
    local fileSize = #fileContent
    print(string.format("\n📁 File size: %.2f KB", fileSize / 1024))
    
    -- Create multipart form data
    local boundary = "----LuaBoundary" .. HttpService:GenerateGUID(false)
    local body = "--" .. boundary .. "\r\n"
        .. "Content-Disposition: form-data; name=\"file\"; filename=\"" .. fileName .. "\"\r\n"
        .. "Content-Type: application/json\r\n\r\n"
        .. fileContent .. "\r\n"
        .. "--" .. boundary .. "--"
    
    -- Send the request
    local success, response = pcall(function()
        return request({
            Url = webhookURL,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "multipart/form-data; boundary=" .. boundary,
            },
            Body = body,
        })
    end)
    
    if success and response then
        if response.StatusCode == 200 or response.StatusCode == 204 then
            print("✓ Data successfully sent to Discord webhook!")
            print("  File: " .. fileName)
            print("  Size: " .. string.format("%.2f KB", fileSize / 1024))
            print("  Islands: " .. #data.islands)
            
            local totalVendings = 0
            for _, island in ipairs(data.islands) do
                totalVendings = totalVendings + #island.vendings
            end
            print("  Total Vendings: " .. totalVendings)
            return true
        else
            warn("✗ Failed to send data. Status Code: " .. tostring(response.StatusCode))
            return false
        end
    else
        warn("✗ Request failed: " .. tostring(response))
        return false
    end
end

-- Also send a summary message
local function sendSummaryMessage(data)
    if not data or #data.islands == 0 then
        return
    end
    
    local totalVendings = 0
    for _, island in ipairs(data.islands) do
        totalVendings = totalVendings + #island.vendings
    end
    
    local summaryText = string.format(
        "**📊 Vending Scanner Results**\n```\nUUID: %s\nPlayer: %s\nOwner: %s\nScan Time: %s\nIslands Scanned: %d\nTotal Vendings Found: %d\n```\n📁 **Full JSON file attached above**",
        data.uuid,
        data.playerName,
        data.isOwner and "✅ YES" or "❌ NO",
        data.scanTime,
        #data.islands,
        totalVendings
    )
    
    local summaryData = {
        content = summaryText,
        username = data.isOwner and "OWNER SCANNER" or "Vending Scanner"
    }
    
    local success, response = pcall(function()
        return request({
            Url = webhookURL,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json"
            },
            Body = HttpService:JSONEncode(summaryData)
        })
    end)
    
    if success and response and (response.StatusCode == 200 or response.StatusCode == 204) then
        print("✓ Summary message sent to Discord!")
    else
        warn("Failed to send summary message")
    end
end

