-- Test webhook connection first
local function testWebhook()
    local http = game:GetService("HttpService")
    local testData = {
        content = "🔍 Vending Scanner is online! Testing connection...",
        username = "Vending Scanner"
    }
    
    local success, response = pcall(function()
        return http:PostAsync(webhookURL, http:JSONEncode(testData), Enum.HttpContentType.ApplicationJson)
    end)
    
    if success then
        print("✓ Webhook connection successful!")
        return true
    else
        warn("✗ Webhook connection failed: " .. tostring(response))
        print("Make sure HTTP requests are enabled in Game Settings > Security")
        return false
    end
end

-- Generate random UUID
local function generateUUID()
    local letters = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    local uuid = ""
    for i = 1, 10 do
        local randomIndex = math.random(1, #letters)
        uuid = uuid .. string.sub(letters, randomIndex, randomIndex)
    end
    return uuid
end

-- Check for buy vending at specific block
local function checkBuyVending(block)
    local sellingContents = block:FindFirstChild("SellingContents")
    if sellingContents then
        local vendingMachine = sellingContents:FindFirstChild("vendingMachine1")
        if vendingMachine then
            local amount = vendingMachine:FindFirstChild("Amount")
            local displayName = vendingMachine:FindFirstChild("DisplayName")
            if amount and displayName then
                return true, amount.Value, displayName.Value
            end
        end
    end
    return false, nil, nil
end

-- Scan all vending blocks
local blockIndex = 0
local buyVendingFound = false

for _, block in ipairs(blocks:GetChildren()) do
    blockIndex = blockIndex + 1
    local name = string.lower(block.Name or "")
    
    -- Check for buy vending at index 2103
    local isBuyVending = false
    local buyAmount = nil
    local buyDisplayName = nil
    
    if blockIndex == 2103 then
        isBuyVending, buyAmount, buyDisplayName = checkBuyVending(block)
        if isBuyVending then
            buyVendingFound = true
            print("✓ Found BUY vending at block 2103!")
        end
    end
    
    -- Check for sell vending
    if string.find(name, "vending") or isBuyVending then
        
        local transactionPrice = block:FindFirstChild("TransactionPrice")
        local mode = block:FindFirstChild("Mode")
        local sellingContents = block:FindFirstChild("SellingContents")
        local displayName = nil
        local priceValue = nil
        local modeValue = nil
        local vendingType = "UNKNOWN"
        
        -- Handle buy vending
        if isBuyVending and blockIndex == 2103 then
            displayName = buyDisplayName
            priceValue = buyAmount
            modeValue = "Buy"
            vendingType = "BUY"
        else
            -- Handle sell vending
            if transactionPrice then
                priceValue = transactionPrice.Value
            end
            
            if mode then
                modeValue = mode.Value
            end
            
            if sellingContents then
                local crate = sellingContents:FindFirstChild("crateMetalPineapple")
                if crate and crate:FindFirstChild("DisplayName") then
                    displayName = crate.DisplayName.Value
                    vendingType = "SELL"
                end
            end
        end
        
        -- Add to results
        table.insert(results, {
            blockIndex = blockIndex,
            blockName = block.Name,
            vendingType = vendingType,
            itemName = displayName or "Unknown",
            price = priceValue,
            mode = modeValue or "Unknown",
            isSpecialBuyBlock = (blockIndex == 2103 and isBuyVending)
        })
        
        print(string.format("Found: %s at block %d | Price: %s | Mode: %s",
            displayName or block.Name,
            blockIndex,
            tostring(priceValue or "N/A"),
            modeValue or "N/A"))
    end
end

-- Send data to Discord
local function sendToDiscord()
    local http = game:GetService("HttpService")
    local uuid = generateUUID()
    
    -- Create summary message
    local summaryText = string.format(
        "**📊 Vending Scanner Results**\n```\nUUID: %s\nPlayer: %s\nOwner: %s\nIsland: %s\nTotal Vendings: %d\nBuy Vending Found: %s\n```",
        uuid,
        playerName,
        isOwner and "✅ YES" or "❌ NO",
        islandId or "Unknown",
        #results,
        buyVendingFound and "✅ YES (Block 2103)" or "❌ NO"
    )
    
    -- Send summary
    local summaryData = {
        content = summaryText,
        username = isOwner and "OWNER SCANNER" or "Vending Scanner"
    }
    
    local success, response = pcall(function()
        return http:PostAsync(webhookURL, http:JSONEncode(summaryData), Enum.HttpContentType.ApplicationJson)
    end)
    
    if not success then
        warn("Failed to send summary: " .. tostring(response))
        return false
    end
    
    wait(1)
    
    -- Send each vending item individually
    for _, vending in ipairs(results) do
        local itemText = string.format(
            "**🛒 Vending Item**\n```\nType: %s\nBlock Index: %d\nItem: %s\nPrice: %s\nMode: %s\n```",
            vending.vendingType,
            vending.blockIndex,
            vending.itemName,
            tostring(vending.price or "N/A"),
            vending.mode
        )
        
        local itemData = {
            content = itemText,
            username = isOwner and "OWNER SCANNER" or "Vending Scanner"
        }
        
        local itemSuccess = pcall(function()
            return http:PostAsync(webhookURL, http:JSONEncode(itemData), Enum.HttpContentType.ApplicationJson)
        end)
        
        if itemSuccess then
            print("Sent item: " .. vending.itemName)
        else
            warn("Failed to send item: " .. vending.itemName)
        end
        
        wait(0.5) -- Rate limit protection
    end
    
    -- Send full JSON as a code block
    local jsonDataStructure = {
        uuid = uuid,
        playerName = playerName,
        isOwner = isOwner,
        islandId = islandId,
        scanTime = os.date("!%Y-%m-%d %H:%M:%S UTC"),
        totalVendingsFound = #results,
        buyVendingFound = buyVendingFound,
        vendings = results
    }
    
    local jsonString = http:JSONEncode(jsonDataStructure)
    
    -- Split JSON into chunks if too long
    local maxLength = 1900
    if #jsonString > maxLength then
        local chunks = {}
        for i = 1, #jsonString, maxLength do
            table.insert(chunks, string.sub(jsonString, i, i + maxLength - 1))
        end
        
        for i, chunk in ipairs(chunks) do
            local chunkData = {
                content = string.format("```json\n%s\n```", chunk),
                username = isOwner and "OWNER SCANNER" or "Vending Scanner"
            }
            pcall(function()
                http:PostAsync(webhookURL, http:JSONEncode(chunkData), Enum.HttpContentType.ApplicationJson)
            end)
            wait(0.5)
        end
    else
        local fullData = {
            content = string.format("```json\n%s\n```", jsonString),
            username = isOwner and "OWNER SCANNER" or "Vending Scanner"
        }
        pcall(function()
            http:PostAsync(webhookURL, http:JSONEncode(fullData), Enum.HttpContentType.ApplicationJson)
        end)
    end
    
    return true
end

