-- Function to generate random 10-letter UUID
local function generateUUID()
    local letters = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    local uuid = ""
    for i = 1, 10 do
        local randomIndex = math.random(1, #letters)
        uuid = uuid .. string.sub(letters, randomIndex, randomIndex)
    end
    return uuid
end

-- Function to check if it's a buy vending (with vendingMachine1)
local function checkBuyVending(block)
    local sellingContents = block:FindFirstChild("SellingContents")
    if sellingContents then
        local vendingMachine = sellingContents:FindFirstChild("vendingMachine1")
        if vendingMachine then
            local amount = vendingMachine:FindFirstChild("Amount")
            local displayName = vendingMachine:FindFirstChild("DisplayName")
            if amount and displayName then
                return true, amount.Value, displayName.Value
            end
        end
    end
    return false, nil, nil
end

-- Scan ALL vending blocks
local blockIndex = 0
for _, block in ipairs(blocks:GetChildren()) do
    blockIndex = blockIndex + 1
    local name = string.lower(block.Name or "")
    
    -- Check for specific block at index 2103 (for buy mode detection)
    local isSpecificBuyBlock = false
    local specificAmount = nil
    local specificDisplayName = nil
    
    if blockIndex == 2103 then
        -- Check the specific block for buy vending structure
        isSpecificBuyBlock, specificAmount, specificDisplayName = checkBuyVending(block)
        if isSpecificBuyBlock then
            print("✓ Found BUY vending at block index 2103!")
            print("  Amount: " .. tostring(specificAmount))
            print("  DisplayName: " .. tostring(specificDisplayName))
        end
    end
    
    -- Check for regular vending blocks
    if string.find(name, "vending") or isSpecificBuyBlock then
        
        local transactionPrice = block:FindFirstChild("TransactionPrice")
        local mode = block:FindFirstChild("Mode")
        local sellingContents = block:FindFirstChild("SellingContents")
        local displayName = nil
        local priceValue = nil
        local modeValue = nil
        local vendingType = "SELL" -- Default to sell
        
        -- If it's the specific buy block, use that data
        if isSpecificBuyBlock and blockIndex == 2103 then
            displayName = specificDisplayName
            priceValue = specificAmount
            modeValue = "Buy"
            vendingType = "BUY"
        else
            -- Regular sell vending detection
            if transactionPrice then
                priceValue = transactionPrice.Value
            end
            
            if mode then
                modeValue = mode.Value
            end
            
            -- Get item name from crateMetalPineapple
            if sellingContents then
                local crate = sellingContents:FindFirstChild("crateMetalPineapple")
                if crate and crate:FindFirstChild("DisplayName") then
                    displayName = crate.DisplayName.Value
                    vendingType = "SELL"
                end
            end
        end
        
        -- Add vending block to results
        table.insert(results, {
            blockIndex = blockIndex,
            blockName = block.Name,
            vendingType = vendingType,
            itemName = displayName or "Unknown",
            price = priceValue,
            mode = modeValue or (vendingType == "BUY" and "Buy" or "Unknown"),
            isSpecialBuyBlock = (blockIndex == 2103 and isSpecificBuyBlock),
            hasPrice = transactionPrice ~= nil or (blockIndex == 2103 and specificAmount ~= nil),
            hasMode = mode ~= nil or (blockIndex == 2103),
            hasItem = displayName ~= nil
        })
        
        print(string.format("[%s] Block %d: %s | Type: %s | Item: %s | Price: %s | Mode: %s",
            vendingType,
            blockIndex,
            block.Name,
            vendingType,
            displayName or "MISSING",
            tostring(priceValue or "MISSING"),
            modeValue or "MISSING"))
    end
end

-- Function to create JSON file and send to Discord (fixed for HTTP requests)
local function sendJSONToDiscord()
    if #results == 0 then
        print("No vending blocks found at all!")
        return
    end
    
    local http = game:GetService("HttpService")
    local uuid = generateUUID()
    
    -- Prepare the complete data structure with owner info
    local jsonDataStructure = {
        uuid = uuid,
        playerName = playerName,
        isOwner = isOwner,
        ownerName = isOwner and ownerName or nil,
        islandId = islandId,
        scanTime = os.date("!%Y-%m-%d %H:%M:%S UTC"),
        totalVendingsFound = #results,
        vendings = results
    }
    
    -- Encode to JSON
    local jsonString = http:JSONEncode(jsonDataStructure)
    
    -- Send as JSON file using simple POST with file attachment workaround
    -- Discord webhooks accept raw JSON in the body with a file attachment
    local success, response = pcall(function()
        -- Create a simple text message with the JSON as a code block (fallback)
        -- Some Roblox versions don't support MultipartFormData properly
        local message = {
            content = string.format(
                "```json\n%s\n```",
                string.sub(jsonString, 1, 1900) -- Discord limit for message content
            ),
            username = isOwner and "OWNER SCANNER" or "Vending Scanner"
        }
        
        -- Also send the full JSON as an attachment using a different method
        -- Create a temporary message with the JSON data
        local fullDataMessage = {
            content = string.format(
                "**Vending Data - %s**\nPlayer: %s\nOwner: %s\nTotal Vendings: %d\n\n📄 Full data below:",
                uuid,
                playerName,
                isOwner and "YES" or "NO",
                #results
            ),
            username = isOwner and "OWNER SCANNER" or "Vending Scanner"
        }
        
        -- Send the summary first
        http:PostAsync(webhookURL, http:JSONEncode(fullDataMessage), Enum.HttpContentType.ApplicationJson)
        
        -- Wait a bit
        wait(1)
        
        -- Send the actual JSON data in chunks if needed
        local chunkSize = 1900
        for i = 1, #jsonString, chunkSize do
            local chunk = string.sub(jsonString, i, math.min(i + chunkSize - 1, #jsonString))
            local chunkMessage = {
                content = string.format("```json\n%s\n```", chunk),
                username = isOwner and "OWNER SCANNER" or "Vending Scanner"
            }
            http:PostAsync(webhookURL, http:JSONEncode(chunkMessage), Enum.HttpContentType.ApplicationJson)
            wait(0.5) -- Rate limiting
        end
        
        return true
    end)
    
    if success then
        print("✓ JSON data sent successfully!")
        print("  UUID: " .. uuid)
        print("  Total vendings: " .. #results)
        
        -- Send owner status highlight
        if isOwner then
            local ownerAlert = {
                content = "🔥 **OWNER DETECTED!** 🔥\nPlayer: " .. playerName .. " has the owner image!",
                username = "OWNER ALERT"
            }
            pcall(function()
                http:PostAsync(webhookURL, http:JSONEncode(ownerAlert), Enum.HttpContentType.ApplicationJson)
            end)
        end
    else
        warn("✗ Failed to send JSON data: " .. tostring(response))
    end
end

