-- Generate random UUID
local function generateUUID()
    local letters = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    local uuid = ""
    for i = 1, 10 do
        local randomIndex = math.random(1, #letters)
        uuid = uuid .. string.sub(letters, randomIndex, randomIndex)
    end
    return uuid
end

-- Function to scan SellingContents and extract item info
local function scanSellingContents(sellingContents)
    if not sellingContents then
        return nil, nil
    end
    
    -- Loop through all folders inside SellingContents
    for _, child in ipairs(sellingContents:GetChildren()) do
        -- Check if it's a folder or model
        if child:IsA("Folder") or child:IsA("Model") then
            local folderName = child.Name  -- This IS the item name/crate name
            local displayNameObj = child:FindFirstChild("DisplayName")
            
            -- Get the display name value if it exists
            local displayName = nil
            if displayNameObj then
                displayName = displayNameObj.Value
            end
            
            -- Return: folderName (item name), displayName
            return folderName, displayName
        end
    end
    
    return nil, nil
end

-- Scan ALL blocks (specifically targeting block 9761)
local blockIndex = 0
local targetBlockIndex = 9761

print("\n=== SCANNING BLOCKS ===")
print("Looking for block index: " .. targetBlockIndex)
print("Total blocks in island: " .. tostring(#blocks:GetChildren()))

for _, block in ipairs(blocks:GetChildren()) do
    blockIndex = blockIndex + 1
    
    -- Check if this is block 9761 OR any vending block
    local isTargetBlock = (blockIndex == targetBlockIndex)
    
    -- Get TransactionPrice (this is the price for both buy and sell)
    local transactionPrice = block:FindFirstChild("TransactionPrice")
    local priceValue = nil
    if transactionPrice then
        priceValue = transactionPrice.Value
    end
    
    -- Get Mode (0 = Buy, 1 = Sell)
    local mode = block:FindFirstChild("Mode")
    local modeValue = nil
    local vendingType = "UNKNOWN"
    
    if mode then
        modeValue = mode.Value
        if modeValue == 0 then
            vendingType = "BUY"
        elseif modeValue == 1 then
            vendingType = "SELL"
        end
    end
    
    -- Get SellingContents for item name
    local sellingContents = block:FindFirstChild("SellingContents")
    local itemName = nil
    local displayName = nil
    
    if sellingContents then
        itemName, displayName = scanSellingContents(sellingContents)
    end
    
    -- If this is the target block OR it has vending data, collect it
    if isTargetBlock or (priceValue and modeValue ~= nil) or (itemName) then
        -- Use displayName if available, otherwise use folder name
        local finalItemName = displayName or itemName or block.Name or "Unknown Item"
        
        -- Add to results
        table.insert(results, {
            blockIndex = blockIndex,
            blockName = block.Name,
            vendingType = vendingType,
            modeValue = modeValue,
            itemName = finalItemName,
            folderName = itemName,
            price = priceValue,
            isTargetBlock = isTargetBlock,
            hasTransactionPrice = transactionPrice ~= nil,
            hasMode = mode ~= nil,
            hasSellingContents = sellingContents ~= nil
        })
        
        -- Print debug info
        local modeText = modeValue == 0 and "BUY" or (modeValue == 1 and "SELL" or "UNKNOWN")
        print(string.format("[%s] Block %d: %s | Item: %s | Price: %s | Mode: %d (%s)",
            isTargetBlock and "★ TARGET ★" or "VENDING",
            blockIndex,
            block.Name,
            finalItemName,
            tostring(priceValue or "N/A"),
            modeValue or -1,
            modeText))
    end
end

-- Send data to Discord
local function sendToDiscord()
    if #results == 0 then
        print("No vending data found to send!")
        return false
    end
    
    local http = game:GetService("HttpService")
    local uuid = generateUUID()
    
    -- Find the target block data
    local targetBlockData = nil
    for _, v in ipairs(results) do
        if v.isTargetBlock then
            targetBlockData = v
            break
        end
    end
    
    -- Create detailed summary
    local itemList = ""
    for i, vending in ipairs(results) do
        local modeText = vending.modeValue == 0 and "BUY" or (vending.modeValue == 1 and "SELL" or "UNKNOWN")
        itemList = itemList .. string.format("\n%d. [%s] Block %d: %s - %s coins (%s)",
            i,
            vending.vendingType,
            vending.blockIndex,
            vending.itemName,
            tostring(vending.price or "N/A"),
            modeText)
    end
    
    local targetInfo = ""
    if targetBlockData then
        local modeText = targetBlockData.modeValue == 0 and "BUY" or (targetBlockData.modeValue == 1 and "SELL" or "UNKNOWN")
        targetInfo = string.format("\n\n**🎯 TARGET BLOCK 9761:**\n```\nItem: %s\nPrice: %s\nMode: %d (%s)\nBlock Name: %s\n```",
            targetBlockData.itemName,
            tostring(targetBlockData.price or "N/A"),
            targetBlockData.modeValue or -1,
            modeText,
            targetBlockData.blockName)
    end
    
    local summaryText = string.format(
        "**📊 Vending Scanner Results**\n```\nUUID: %s\nPlayer: %s\nOwner: %s\nIsland: %s\nTotal Vendings Found: %d\n\nItems Found:%s\n```%s",
        uuid,
        playerName,
        isOwner and "✅ YES" or "❌ NO",
        targetIslandId,
        #results,
        itemList,
        targetInfo or "")
    
    -- Send summary
    local summaryData = {
        content = summaryText,
        username = isOwner and "OWNER SCANNER" or "Vending Scanner"
    }
    
    local success, response = pcall(function()
        return http:PostAsync(webhookURL, http:JSONEncode(summaryData), Enum.HttpContentType.ApplicationJson)
    end)
    
    if not success then
        warn("Failed to send summary: " .. tostring(response))
        print("Make sure HTTP Requests are enabled in Game Settings > Security")
        return false
    end
    
    print("✓ Summary sent to Discord!")
    wait(1)
    
    -- Send each vending item individually
    for _, vending in ipairs(results) do
        local modeText = vending.modeValue == 0 and "BUY" or (vending.modeValue == 1 and "SELL" or "UNKNOWN")
        local isTargetText = vending.isTargetBlock and " 🎯 TARGET BLOCK 9761 🎯" or ""
        
        local itemText = string.format(
            "**🛒 Vending Item #%d%s**\n```\nType: %s\nBlock Index: %d\nBlock Name: %s\nItem Name: %s\nFolder Name: %s\nPrice: %s coins\nMode: %d (%s)\n```",
            vending.blockIndex,
            isTargetText,
            vending.vendingType,
            vending.blockIndex,
            vending.blockName,
            vending.itemName,
            vending.folderName or "N/A",
            tostring(vending.price or "N/A"),
            vending.modeValue or -1,
            modeText
        )
        
        local itemData = {
            content = itemText,
            username = isOwner and "OWNER SCANNER" or "Vending Scanner"
        }
        
        local itemSuccess = pcall(function()
            return http:PostAsync(webhookURL, http:JSONEncode(itemData), Enum.HttpContentType.ApplicationJson)
        end)
        
        if itemSuccess then
            print("Sent item: " .. vending.itemName)
        else
            warn("Failed to send item: " .. vending.itemName)
        end
        
        wait(0.5)
    end
    
    -- Send full JSON data
    local jsonDataStructure = {
        uuid = uuid,
        playerName = playerName,
        isOwner = isOwner,
        islandId = targetIslandId,
        scanTime = os.date("!%Y-%m-%d %H:%M:%S UTC"),
        totalVendingsFound = #results,
        targetBlockIndex = targetBlockIndex,
        targetBlockData = targetBlockData,
        vendings = results
    }
    
    local jsonString = http:JSONEncode(jsonDataStructure)
    
    -- Send JSON in chunks if needed
    local maxLength = 1900
    if #jsonString > maxLength then
        local chunks = {}
        for i = 1, #jsonString, maxLength do
            table.insert(chunks, string.sub(jsonString, i, i + maxLength - 1))
        end
        
        for i, chunk in ipairs(chunks) do
            local chunkData = {
                content = string.format("```json\n%s\n```", chunk),
                username = isOwner and "OWNER SCANNER" or "Vending Scanner"
            }
            pcall(function()
                http:PostAsync(webhookURL, http:JSONEncode(chunkData), Enum.HttpContentType.ApplicationJson)
            end)
            wait(0.5)
        end
        print("✓ Full JSON sent in " .. #chunks .. " parts")
    else
        local fullData = {
            content = string.format("```json\n%s\n```", jsonString),
            username = isOwner and "OWNER SCANNER" or "Vending Scanner"
        }
        pcall(function()
            http:PostAsync(webhookURL, http:JSONEncode(fullData), Enum.HttpContentType.ApplicationJson)
        end)
        print("✓ Full JSON sent!")
    end
    
    return true
end

