-- Function to generate random 10-letter UUID
local function generateUUID()
    local letters = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    local uuid = ""
    for i = 1, 10 do
        local randomIndex = math.random(1, #letters)
        uuid = uuid .. string.sub(letters, randomIndex, randomIndex)
    end
    return uuid
end

-- Scan ALL vending blocks (including those with nil values)
for _, block in ipairs(blocks:GetChildren()) do
    local name = string.lower(block.Name or "")

    if string.find(name, "vending") then
        
        local transactionPrice = block:FindFirstChild("TransactionPrice")
        local mode = block:FindFirstChild("Mode")
        local sellingContents = block:FindFirstChild("SellingContents")
        local displayName = nil
        local priceValue = nil
        local modeValue = nil
        
        -- Get price (keep nil if doesn't exist)
        if transactionPrice then
            priceValue = transactionPrice.Value
        end
        
        -- Get mode (keep nil if doesn't exist)
        if mode then
            modeValue = mode.Value
        end
        
        -- Get item name (keep nil if doesn't exist)
        if sellingContents then
            local crate = sellingContents:FindFirstChild("crateMetalPineapple")
            if crate and crate:FindFirstChild("DisplayName") then
                displayName = crate.DisplayName.Value
            end
        end
        
        -- Add ALL vending blocks to results (including those with nil values)
        table.insert(results, {
            blockName = block.Name,
            itemName = displayName or "Unknown",
            price = priceValue,
            mode = modeValue or "Unknown",
            hasPrice = transactionPrice ~= nil,
            hasMode = mode ~= nil,
            hasItem = displayName ~= nil
        })
        
        print(string.format("Found vending: %s | Item: %s | Price: %s | Mode: %s",
            block.Name,
            displayName or "MISSING",
            tostring(priceValue or "MISSING"),
            modeValue or "MISSING"))
    end
end

-- Function to create JSON file and send to Discord
local function sendJSONToDiscord()
    if #results == 0 then
        print("No vending blocks found at all!")
        return
    end
    
    local http = game:GetService("HttpService")
    local uuid = generateUUID()
    
    -- Prepare the complete data structure with owner info
    local jsonDataStructure = {
        uuid = uuid,
        playerName = playerName,
        isOwner = isOwner,
        ownerName = isOwner and ownerName or nil,
        islandId = islandId,
        scanTime = os.date("!%Y-%m-%d %H:%M:%S UTC"),
        totalVendingsFound = #results,
        vendings = results
    }
    
    -- Encode to JSON
    local jsonString = http:JSONEncode(jsonDataStructure)
    
    -- Create multipart form data to send as file
    local boundary = "boundary_" .. tostring(math.random(1000000, 9999999))
    local fileContent = "--" .. boundary .. "\r\n"
    fileContent = fileContent .. 'Content-Disposition: form-data; name="file"; filename="vending_data_' .. uuid .. '.json"\r\n'
    fileContent = fileContent .. "Content-Type: application/json\r\n\r\n"
    fileContent = fileContent .. jsonString .. "\r\n"
    fileContent = fileContent .. "--" .. boundary .. "--\r\n"
    
    -- Send file to Discord webhook
    local success, response = pcall(function()
        return http:PostAsync(webhookURL, fileContent, Enum.HttpContentType.MultipartFormData, function(generatedBoundary)
            return boundary
        end)
    end)
    
    if success then
        print("✓ JSON file sent successfully!")
        print("  UUID: " .. uuid)
        print("  Total vendings: " .. #results)
        
        -- Send a simple text confirmation with owner status
        local ownerStatusText = isOwner and "👑 **OWNER** 👑" or "Regular Player"
        local confirmMessage = {
            content = string.format(
                "%s\n```\nUUID: %s\nPlayer: %s\nStatus: %s\nIsland: %s\nTotal Vendings: %d\nTime: %s\n```\n📁 **Full data in attached JSON file**",
                isOwner and "🔥 **OWNER DETECTED** 🔥" or "📊 Vending Data Collected",
                uuid,
                playerName,
                ownerStatusText,
                islandId or "Unknown",
                #results,
                os.date("!%Y-%m-%d %H:%M:%S UTC")
            ),
            username = isOwner and "OWNER SCANNER" or "Vending Scanner"
        }
        
        local confirmSuccess = pcall(function()
            return http:PostAsync(webhookURL, http:JSONEncode(confirmMessage), Enum.HttpContentType.ApplicationJson)
        end)
        
        if confirmSuccess then
            print("✓ Confirmation message sent!")
        end
    else
        warn("✗ Failed to send JSON file: " .. tostring(response))
    end
end

-- Send ALL data as one JSON file
print("\n=== SCANNING VENDING BLOCKS ===")
sendJSONToDiscord()
print("=============================")
