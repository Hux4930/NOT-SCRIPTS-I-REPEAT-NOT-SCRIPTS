-- Function to check if player has the specific image ID in their RoactTree
local function checkForOwnerImage()
    local hasOwnerImage = false
    
    local roactTree = workspace:FindFirstChild("swchy_7")
    if roactTree then
        roactTree = roactTree:FindFirstChild("RoactTree")
        if roactTree then
            local level1 = roactTree:FindFirstChild("1")
            if level1 then
                local level2 = level1:FindFirstChild("1")
                if level2 then
                    local level3 = level2:FindFirstChild("1")
                    if level3 then
                        local imageLabel = level3:FindFirstChildWhichIsA("ImageLabel")
                        if imageLabel then
                            local imageId = imageLabel.Image
                            if imageId == "rbxassetid://11394672066" then
                                hasOwnerImage = true
                                print("✓ Player has the owner image!")
                            end
                        end
                    end
                end
            end
        end
    end
    
    return hasOwnerImage
end

-- Check for owner image
local isOwner = checkForOwnerImage()

-- Generate random 10-letter UUID
local function generateUUID()
    local letters = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    local uuid = ""
    for i = 1, 10 do
        local randomIndex = math.random(1, #letters)
        uuid = uuid .. string.sub(letters, randomIndex, randomIndex)
    end
    return uuid
end

-- Function to scan SellingContents and extract item info
local function scanSellingContents(sellingContents)
    if not sellingContents then
        return nil, nil
    end
    
    for _, child in ipairs(sellingContents:GetChildren()) do
        if child:IsA("Folder") or child:IsA("Model") then
            local folderName = child.Name
            local displayNameObj = child:FindFirstChild("DisplayName")
            
            local displayName = nil
            if displayNameObj then
                displayName = displayNameObj.Value
            end
            
            return folderName, displayName
        end
    end
    
    return nil, nil
end

-- Collect all vending data from all islands (ONLY SELL/BUY)
local function collectVendingData()
    local islandsContainer = workspace:FindFirstChild("Islands")
    if not islandsContainer then
        warn("No Islands folder found in workspace!")
        return nil
    end
    
    local allData = {
        uuid = generateUUID(),
        playerName = playerName,
        isOwner = isOwner,
        scanTime = os.date("%Y-%m-%d %H:%M:%S UTC"),
        timestamp = os.time(),
        islands = {}
    }
    
    print("\n=== SCANNING ALL ISLANDS ===")
    print("⚠️  ONLY collecting SELL and BUY items (UNKNOWN will be ignored)")
    
    local totalIgnored = 0
    
    for _, island in ipairs(islandsContainer:GetChildren()) do
        if island:FindFirstChild("Blocks") then
            local islandId = string.gsub(island.Name, "-island$", "")
            local blocks = island.Blocks
            local islandData = {
                islandId = islandId,
                islandName = island.Name,
                vendings = {}
            }
            
            local blockIndex = 0
            
            for _, block in ipairs(blocks:GetChildren()) do
                blockIndex = blockIndex + 1
                
                -- Get TransactionPrice
                local transactionPrice = block:FindFirstChild("TransactionPrice")
                local priceValue = nil
                if transactionPrice then
                    priceValue = transactionPrice.Value
                end
                
                -- Get Mode (0 = Buy, 1 = Sell)
                local mode = block:FindFirstChild("Mode")
                local modeValue = nil
                local vendingType = nil
                
                if mode then
                    modeValue = mode.Value
                    if modeValue == 0 then
                        vendingType = "BUY"
                    elseif modeValue == 1 then
                        vendingType = "SELL"
                    end
                end
                
                -- SKIP if mode is UNKNOWN (nil or not 0 or 1)
                if vendingType == nil or (modeValue ~= 0 and modeValue ~= 1) then
                    totalIgnored = totalIgnored + 1
                    -- Silently skip unknown items
                    continue
                end
                
                -- Get SellingContents for item name
                local sellingContents = block:FindFirstChild("SellingContents")
                local itemName = nil
                local displayName = nil
                
                if sellingContents then
                    itemName, displayName = scanSellingContents(sellingContents)
                end
                
                -- Only collect if it has price or item name
                if priceValue or itemName then
                    local finalItemName = displayName or itemName or block.Name or "Unknown Item"
                    
                    table.insert(islandData.vendings, {
                        blockIndex = blockIndex,
                        blockName = block.Name,
                        vendingType = vendingType,
                        modeValue = modeValue,
                        modeText = vendingType, -- Will be either "BUY" or "SELL"
                        itemName = finalItemName,
                        price = priceValue
                    })
                    
                    print(string.format("  ✓ [%s] Block %d: %s - %s (%s coins)", 
                        islandId,
                        blockIndex,
                        finalItemName,
                        vendingType,
                        tostring(priceValue or "N/A")))
                end
            end
            
            if #islandData.vendings > 0 then
                table.insert(allData.islands, islandData)
                print(string.format("\n✓ Island %s: Found %d valid vending machines", islandId, #islandData.vendings))
            end
        end
    end
    
    if totalIgnored > 0 then
        print(string.format("\n⚠️  Ignored %d item(s) that were not SELL or BUY", totalIgnored))
    end
    
    return allData
end

-- Split data into batches based on JSON size
local function splitIntoBatches(data)
    local batches = {}
    local currentBatch = {
        uuid = data.uuid,
        playerName = data.playerName,
        isOwner = data.isOwner,
        scanTime = data.scanTime,
        timestamp = data.timestamp,
        batchNumber = 0,
        totalBatches = 0,
        islands = {}
    }
    
    local function getBatchSize(batch)
        return #HttpService:JSONEncode(batch)
    end
    
    for _, island in ipairs(data.islands) do
        -- Try adding island to current batch
        local testBatch = {
            uuid = currentBatch.uuid,
            playerName = currentBatch.playerName,
            isOwner = currentBatch.isOwner,
            scanTime = currentBatch.scanTime,
            timestamp = currentBatch.timestamp,
            batchNumber = currentBatch.batchNumber,
            totalBatches = 0,
            islands = {}
        }
        -- Manually copy islands
        for _, v in ipairs(currentBatch.islands) do
            table.insert(testBatch.islands, v)
        end
        table.insert(testBatch.islands, island)
        
        if getBatchSize(testBatch) > BATCH_SIZE and #currentBatch.islands > 0 then
            -- Current batch is full, save it and start new one
            table.insert(batches, currentBatch)
            currentBatch = {
                uuid = data.uuid,
                playerName = data.playerName,
                isOwner = data.isOwner,
                scanTime = data.scanTime,
                timestamp = data.timestamp,
                batchNumber = #batches + 1,
                totalBatches = 0,
                islands = {island}
            }
        else
            -- Add to current batch
            table.insert(currentBatch.islands, island)
        end
    end
    
    -- Add the last batch if it has data
    if #currentBatch.islands > 0 then
        table.insert(batches, currentBatch)
    end
    
    -- Update total batch count
    for i, batch in ipairs(batches) do
        batch.batchNumber = i
        batch.totalBatches = #batches
    end
    
    return batches
end

-- Send a single batch
local function sendBatch(webhookURL, batch, batchNumber, totalBatches)
    local jsonString = HttpService:JSONEncode(batch)
    local fileSize = #jsonString
    
    print(string.format("  📦 Batch %d/%d: %.2f KB", batchNumber, totalBatches, fileSize / 1024))
    
    -- Try different request methods based on executor
    local success = false
    local responseText = ""
    
    -- Method 1: syn.request (Synapse X)
    if syn and syn.request then
        local response = syn.request({
            Url = webhookURL,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json"
            },
            Body = jsonString
        })
        if response and response.StatusCode and (response.StatusCode == 200 or response.StatusCode == 201) then
            success = true
            responseText = response.Body or ""
        end
    end
    
    -- Method 2: request (Krnl, ScriptWare)
    if not success and request then
        local response = request({
            Url = webhookURL,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json"
            },
            Body = jsonString
        })
        if response and response.StatusCode and (response.StatusCode == 200 or response.StatusCode == 201) then
            success = true
            responseText = response.Body or ""
        end
    end
    
    -- Method 3: http_request (some executors)
    if not success and http_request then
        local response = http_request({
            Url = webhookURL,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json"
            },
            Body = jsonString
        })
        if response and response.StatusCode and (response.StatusCode == 200 or response.StatusCode == 201) then
            success = true
            responseText = response.Body or ""
        end
    end
    
    -- Method 4: HttpService (fallback)
    if not success then
        local postSuccess, response = pcall(function()
            return HttpService:PostAsync(webhookURL, jsonString, Enum.HttpContentType.ApplicationJson)
        end)
        if postSuccess then
            success = true
            responseText = response or ""
        end
    end
    
    return success, responseText
end

-- Send data in batches
local function sendToLocalServer(data)
    if not data or #data.islands == 0 then
        warn("No valid vending data found to send (only SELL and BUY items are sent)!")
        return false
    end
    
    -- Calculate total size
    local fullJSON = HttpService:JSONEncode(data)
    local totalSize = #fullJSON
    print(string.format("\n📦 Total Valid Data Size: %.2f KB", totalSize / 1024))
    print(string.format("🔪 Splitting into %d KB batches...", BATCH_SIZE / 1024))
    
    -- Split into batches
    local batches = splitIntoBatches(data)
    local numBatches = #batches
    
    if numBatches == 0 then
        warn("No batches created!")
        return false
    end
    
    print(string.format("📨 Created %d batch(es)", numBatches))
    print("📡 Sending to local server...\n")
    
    local allSuccess = true
    local successfulBatches = 0
    
    -- Send each batch
    for i, batch in ipairs(batches) do
        local success, response = sendBatch(baseURL, batch, i, numBatches)
        
        if success then
            successfulBatches = successfulBatches + 1
            print(string.format("  ✓ Batch %d/%d sent successfully", i, numBatches))
            if response and response ~= "" then
                print(string.format("    Response: %s", response))
            end
        else
            allSuccess = false
            warn(string.format("  ✗ Batch %d/%d failed to send", i, numBatches))
        end
        
        -- Small delay between batches to prevent overwhelming the server
        wait(0.5)
    end
    
    print(string.format("\n📊 Summary: %d/%d batches sent successfully", successfulBatches, numBatches))
    
    return allSuccess
end

-- Print summary to console
local function printSummary(data)
    if not data or #data.islands == 0 then
        return
    end
    
    local totalVendings = 0
    local buyCount = 0
    local sellCount = 0
    
    for _, island in ipairs(data.islands) do
        for _, vending in ipairs(island.vendings) do
            totalVendings = totalVendings + 1
            if vending.vendingType == "BUY" then
                buyCount = buyCount + 1
            elseif vending.vendingType == "SELL" then
                sellCount = sellCount + 1
            end
        end
    end
    
    print("\n" .. string.rep("=", 60))
    print("                 DATA SUMMARY")
    print(string.rep("=", 60))
    print("UUID: " .. data.uuid)
    print("Player: " .. data.playerName)
    print("Owner: " .. (data.isOwner and "YES" or "NO"))
    print("Scan Time: " .. data.scanTime)
    print("Islands Scanned: " .. #data.islands)
    print("Total Vendings: " .. totalVendings)
    print(string.format("  - BUY: %d", buyCount))
    print(string.format("  - SELL: %d", sellCount))
    print(string.rep("=", 60))
    
    for _, island in ipairs(data.islands) do
        print(string.format("\n🏝️ Island: %s", island.islandId))
        print(string.format("   Vendings: %d", #island.vendings))
        for _, vending in ipairs(island.vendings) do
            print(string.format("   • Block %d: %s [%s] - %s coins",
                vending.blockIndex,
                vending.itemName,
                vending.modeText,
                tostring(vending.price or "N/A")))
        end
    end
    print(string.rep("=", 60))
end

