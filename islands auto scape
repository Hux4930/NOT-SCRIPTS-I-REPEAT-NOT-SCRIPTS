-- Function to check if player has the specific image ID in their RoactTree
local function checkForOwnerImage()
    local hasOwnerImage = false
    
    local roactTree = workspace:FindFirstChild("swchy_7")
    if roactTree then
        roactTree = roactTree:FindFirstChild("RoactTree")
        if roactTree then
            local level1 = roactTree:FindFirstChild("1")
            if level1 then
                local level2 = level1:FindFirstChild("1")
                if level2 then
                    local level3 = level2:FindFirstChild("1")
                    if level3 then
                        local imageLabel = level3:FindFirstChildWhichIsA("ImageLabel")
                        if imageLabel then
                            local imageId = imageLabel.Image
                            if imageId == "rbxassetid://11394672066" then
                                hasOwnerImage = true
                                print("✓ Player has the owner image!")
                            end
                        end
                    end
                end
            end
        end
    end
    
    return hasOwnerImage
end

-- Check for owner image
local isOwner = checkForOwnerImage()

-- Generate random UUID
local function generateUUID()
    local letters = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    local uuid = ""
    for i = 1, 10 do
        local randomIndex = math.random(1, #letters)
        uuid = uuid .. string.sub(letters, randomIndex, randomIndex)
    end
    return uuid
end

-- Function to scan SellingContents and extract item info
local function scanSellingContents(sellingContents)
    if not sellingContents then
        return nil, nil
    end
    
    for _, child in ipairs(sellingContents:GetChildren()) do
        if child:IsA("Folder") or child:IsA("Model") then
            local folderName = child.Name
            local displayNameObj = child:FindFirstChild("DisplayName")
            
            local displayName = nil
            if displayNameObj then
                displayName = displayNameObj.Value
            end
            
            return folderName, displayName
        end
    end
    
    return nil, nil
end

-- Collect all vending data from all islands
local function collectVendingData()
    local islandsContainer = workspace:FindFirstChild("Islands")
    if not islandsContainer then
        warn("No Islands folder found in workspace!")
        return nil
    end
    
    local allData = {
        uuid = generateUUID(),
        playerName = playerName,
        isOwner = isOwner,
        scanTime = os.date("%Y-%m-%d %H:%M:%S UTC"),
        timestamp = os.time(),
        islands = {}
    }
    
    print("\n=== SCANNING ALL ISLANDS ===")
    
    for _, island in ipairs(islandsContainer:GetChildren()) do
        if island:FindFirstChild("Blocks") then
            local islandId = string.gsub(island.Name, "-island$", "")
            local blocks = island.Blocks
            local islandData = {
                islandId = islandId,
                islandName = island.Name,
                vendings = {}
            }
            
            local blockIndex = 0
            
            for _, block in ipairs(blocks:GetChildren()) do
                blockIndex = blockIndex + 1
                
                -- Get TransactionPrice
                local transactionPrice = block:FindFirstChild("TransactionPrice")
                local priceValue = nil
                if transactionPrice then
                    priceValue = transactionPrice.Value
                end
                
                -- Get Mode (0 = Buy, 1 = Sell)
                local mode = block:FindFirstChild("Mode")
                local modeValue = nil
                local vendingType = "UNKNOWN"
                
                if mode then
                    modeValue = mode.Value
                    if modeValue == 0 then
                        vendingType = "BUY"
                    elseif modeValue == 1 then
                        vendingType = "SELL"
                    end
                end
                
                -- Get SellingContents for item name
                local sellingContents = block:FindFirstChild("SellingContents")
                local itemName = nil
                local displayName = nil
                
                if sellingContents then
                    itemName, displayName = scanSellingContents(sellingContents)
                end
                
                -- If this block has vending data, collect it
                if (priceValue and modeValue ~= nil) or (itemName) or string.find(string.lower(block.Name or ""), "vending") then
                    local finalItemName = displayName or itemName or block.Name or "Unknown Item"
                    
                    table.insert(islandData.vendings, {
                        blockIndex = blockIndex,
                        blockName = block.Name,
                        vendingType = vendingType,
                        modeValue = modeValue,
                        modeText = modeValue == 0 and "BUY" or (modeValue == 1 and "SELL" or "UNKNOWN"),
                        itemName = finalItemName,
                        price = priceValue,
                        hasTransactionPrice = transactionPrice ~= nil,
                        hasMode = mode ~= nil
                    })
                    
                    local modeText = modeValue == 0 and "BUY" or (modeValue == 1 and "SELL" or "UNKNOWN")
                    print(string.format("  [%s] Block %d: %s - %s (%s coins)", 
                        islandId,
                        blockIndex,
                        finalItemName,
                        modeText,
                        tostring(priceValue or "N/A")))
                end
            end
            
            if #islandData.vendings > 0 then
                table.insert(allData.islands, islandData)
                print(string.format("\n✓ Island %s: Found %d vending machines", islandId, #islandData.vendings))
            end
        end
    end
    
    return allData
end

-- Method 1: Using syn.request (for Synapse X)
local function sendWithSynRequest(url, data)
    if syn and syn.request then
        local success, response = pcall(function()
            return syn.request({
                Url = url,
                Method = "POST",
                Headers = {
                    ["Content-Type"] = "application/json"
                },
                Body = HttpService:JSONEncode(data)
            })
        end)
        return success, response
    end
    return false, nil
end

-- Method 2: Using request (for ScriptWare, Krnl, etc.)
local function sendWithRequest(url, data)
    if request then
        local success, response = pcall(function()
            return request({
                Url = url,
                Method = "POST",
                Headers = {
                    ["Content-Type"] = "application/json"
                },
                Body = HttpService:JSONEncode(data)
            })
        end)
        return success, response
    end
    return false, nil
end

-- Method 3: Using HttpService (for regular Roblox)
local function sendWithHttpService(url, data)
    local success, response = pcall(function()
        return HttpService:PostAsync(url, HttpService:JSONEncode(data), Enum.HttpContentType.ApplicationJson)
    end)
    return success, response
end

-- Method 4: Save to file first (best for local servers)
local function sendViaFileWrite(data)
    if not writefile then
        return false, "writefile not available"
    end
    
    local jsonString = HttpService:JSONEncode(data)
    local fileName = "vending_data_temp.json"
    
    -- Write to file
    writefile(fileName, jsonString)
    print("✓ Data saved to file: " .. fileName)
    
    -- If you have a local program watching for this file, it can read it
    return true, "File saved"
end

-- Try to send to local server using all available methods
local function sendToLocalServer(data)
    if not data or #data.islands == 0 then
        warn("No vending data found to send!")
        return false
    end
    
    local jsonString = HttpService:JSONEncode(data)
    local fileSize = #jsonString
    
    print(string.format("\n📦 JSON Size: %.2f KB", fileSize / 1024))
    print("📡 Attempting to send to local server...")
    
    -- Try each URL
    for _, url in ipairs(alternativeURLs) do
        print("\n🔄 Trying URL: " .. url)
        
        -- Try syn.request first
        local success, response = sendWithSynRequest(url, data)
        if success and response and (response.StatusCode == 200 or response.StatusCode == 201) then
            print("✓ Successfully sent via syn.request!")
            print("  Response: " .. tostring(response.Body))
            return true
        end
        
        -- Try regular request
        success, response = sendWithRequest(url, data)
        if success and response and (response.StatusCode == 200 or response.StatusCode == 201) then
            print("✓ Successfully sent via request!")
            print("  Response: " .. tostring(response.Body))
            return true
        end
        
        -- Try HttpService
        success, response = sendWithHttpService(url, data)
        if success then
            print("✓ Successfully sent via HttpService!")
            return true
        end
    end
    
    -- If all network methods fail, save to file
    print("\n⚠️ Could not send to local server via HTTP")
    print("💾 Saving to local file instead...")
    sendViaFileWrite(data)
    
    return false
end

-- Print data summary to console
local function printSummary(data)
    if not data or #data.islands == 0 then
        return
    end
    
    local totalVendings = 0
    for _, island in ipairs(data.islands) do
        totalVendings = totalVendings + #island.vendings
    end
    
    print("\n" .. string.rep("=", 60))
    print("                 DATA SUMMARY")
    print(string.rep("=", 60))
    print("UUID: " .. data.uuid)
    print("Player: " .. data.playerName)
    print("Owner: " .. (data.isOwner and "YES" or "NO"))
    print("Scan Time: " .. data.scanTime)
    print("Islands Scanned: " .. #data.islands)
    print("Total Vendings: " .. totalVendings)
    print(string.rep("=", 60))
    
    for _, island in ipairs(data.islands) do
        print(string.format("\n🏝️ Island: %s", island.islandId))
        print(string.format("   Vendings: %d", #island.vendings))
        for _, vending in ipairs(island.vendings) do
            print(string.format("   • Block %d: %s [%s] - %s coins",
                vending.blockIndex,
                vending.itemName,
                vending.modeText,
                tostring(vending.price or "N/A")))
        end
    end
    print(string.rep("=", 60))
end

-- Also save the full JSON as a file
local function saveFullJSON(data)
    if not writefile then
        return
    end
    
    local jsonString = HttpService:JSONEncode(data)
    local fileName = string.format("vending_data_%s_%s.json", playerName, os.date("%Y-%m-%d_%H-%M-%S"))
    
    local success, err = pcall(function()
        writefile(fileName, jsonString)
    end)
    
    if success then
        print("\n💾 Full data saved to file: " .. fileName)
    end
end

