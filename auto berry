-- Function to get current crop hash from your system
local function getCurrentCropHash()
    -- Try to get from global variables set by your hash system
    if _G.CropHash then
        hashStatusLabel.Text = "Hash Status: Using _G.CropHash"
        return _G.CropHash
    end
    
    -- Try to get from remote folder
    local remoteFolder = game:FindFirstChild("_REMOTES_NEKO_")
    if remoteFolder and remoteFolder:FindFirstChild("CropHashData") then
        local cropData = remoteFolder.CropHashData.Value
        hashStatusLabel.Text = "Hash Status: Found CropHashData: " .. cropData:sub(1, 30)
        return cropData
    end
    
    -- Try to read from file
    local success, result = pcall(function()
        return readfile("/Hash System/CropHash")
    end)
    if success and result then
        hashStatusLabel.Text = "Hash Status: Loaded from file"
        return result
    end
    
    hashStatusLabel.Text = "Hash Status: No hash found, using default"
    return "🤣🤡\n\n\nsDahbvdxZludavlcoipDDMYasPlcm" -- Default fallback
end

-- Function to extract hash from a crop object
local function extractHashFromCrop(cropModel)
    -- Method 1: Check for hash in attributes
    local hashAttr = cropModel:GetAttribute("HarvestHash")
    if hashAttr then
        return hashAttr
    end
    
    -- Method 2: Check for string value children
    for _, child in ipairs(cropModel:GetChildren()) do
        if child:IsA("StringValue") and (child.Name:lower():find("hash") or child.Name:lower():find("key")) then
            return child.Value
        end
    end
    
    -- Method 3: Check model name for encoded hash
    if cropModel.Name:match("[%z%x%c]+") then
        return cropModel.Name
    end
    
    -- Method 4: Check for values in Configuration folders
    local config = cropModel:FindFirstChild("Configuration")
    if config then
        for _, child in ipairs(config:GetChildren()) do
            if child:IsA("StringValue") then
                return child.Value
            end
        end
    end
    
    return nil
end

-- Function to calculate distance
local function getDistance(position1, position2)
    return (position1 - position2).Magnitude
end

-- Function to find all harvestable objects
local function findHarvestableObjects()
    statusLabel.Text = "Status: Finding objects..."
    harvestableObjects = {}
    local player = game:GetService("Players").LocalPlayer
    local character = player.Character
    local playerPos = character and character.PrimaryPart and character.PrimaryPart.Position or Vector3.new(0, 0, 0)
    
    -- Find all islands
    for islandName, island in pairs(workspace.Islands:GetChildren()) do
        if island:FindFirstChild("Blocks") then
            for blockName, block in pairs(island.Blocks:GetChildren()) do
                -- Check if it's harvestable
                local isHarvestable = false
                local harvestType = nil
                
                if blockName:lower():find("berry") or blockName:lower():find("bush") then
                    isHarvestable = true
                    harvestType = "berry"
                elseif blockName:lower():find("crop") or blockName:lower():find("wheat") then
                    isHarvestable = true
                    harvestType = "crop"
                elseif blockName:lower():find("tree") then
                    isHarvestable = true
                    harvestType = "tree"
                elseif block:IsA("Model") and (block:FindFirstChild("Harvestable") or block:GetAttribute("Harvestable")) then
                    isHarvestable = true
                    harvestType = "other"
                end
                
                if isHarvestable then
                    local blockPos = block:FindFirstChild("Position") and block.Position.Position or 
                                    (block:IsA("BasePart") and block.Position or Vector3.new(0, 0, 0))
                    
                    local distance = getDistance(playerPos, blockPos)
                    
                    -- Try to extract hash from the crop
                    local cropHash = extractHashFromCrop(block)
                    
                    table.insert(harvestableObjects, {
                        name = blockName,
                        model = block,
                        island = island,
                        islandName = islandName,
                        position = blockPos,
                        distance = distance,
                        type = harvestType,
                        hash = cropHash
                    })
                end
            end
        end
    end
    
    -- Sort by distance
    table.sort(harvestableObjects, function(a, b)
        return a.distance < b.distance
    end)
    
    -- Update list display
    local listText = "Found " .. #harvestableObjects .. " harvestable objects:\n\n"
    for i, obj in ipairs(harvestableObjects) do
        local hashInfo = obj.hash and "✓" or "✗"
        listText = listText .. string.format("%d. %s (%.1f studs) [%s] %s\n", 
            i, obj.name, obj.distance, obj.type, hashInfo)
    end
    
    listBox.Text = listText
    statusLabel.Text = "Status: Found " .. #harvestableObjects .. " objects"
    
    if #harvestableObjects == 0 then
        listBox.Text = "No harvestable objects found!\n\nMake sure you're near some harvestable objects."
    end
    
    return harvestableObjects
end

-- Function to harvest a specific object
local function harvestObject(obj, useCustomHash, customHash)
    if not obj or not obj.model then
        statusLabel.Text = "Status: Invalid object!"
        return false
    end
    
    local player = game:GetService("Players").LocalPlayer
    
    -- Determine which hash to use
    local hashToUse
    if useCustomHash and customHash then
        hashToUse = customHash
        statusLabel.Text = "Status: Testing with custom hash on " .. obj.name
    elseif obj.hash then
        hashToUse = obj.hash
        statusLabel.Text = "Status: Using object's hash on " .. obj.name
    else
        hashToUse = getCurrentCropHash()
        statusLabel.Text = "Status: Using system hash on " .. obj.name
    end
    
    currentTarget = obj.name
    targetLabel.Text = "Target: " .. obj.name
    
    -- Get the remote
    local remotePath = "rbxts_include.node_modules[@rbxts].net.out._NetManaged.CLIENT_HARVEST_CROP_REQUEST"
    local remote = game:GetService("ReplicatedStorage"):FindFirstChild(remotePath)
    
    if not remote then
        -- Try alternative path
        remote = game:GetService("ReplicatedStorage"):FindFirstChild("rbxts_include")
        if remote then
            remote = remote:FindFirstChild("node_modules")
            if remote then
                remote = remote:FindFirstChild("@rbxts")
                if remote then
                    remote = remote:FindFirstChild("net")
                    if remote then
                        remote = remote:FindFirstChild("out")
                        if remote then
                            remote = remote:FindFirstChild("_NetManaged")
                            if remote then
                                remote = remote:FindFirstChild("CLIENT_HARVEST_CROP_REQUEST")
                            end
                        end
                    end
                end
            end
        end
    end
    
    if not remote then
        statusLabel.Text = "Status: Cannot find harvest remote!"
        return false
    end
    
    local success, result = pcall(function()
        return remote:InvokeServer({
            ["dZnpyRtxna"] = hashToUse,
            ["player"] = player,
            ["model"] = obj.model,
        })
    end)
    
    if success then
        harvestedCount = harvestedCount + 1
        statusLabel.Text = "Status: Successfully harvested " .. obj.name .. " (#" .. harvestedCount .. ")"
        print("Harvested:", obj.name, "with hash:", hashToUse:sub(1, 30))
        return true
    else
        statusLabel.Text = "Status: Failed to harvest " .. obj.name .. " - " .. tostring(result)
        warn("Failed to harvest:", obj.name, "Error:", result)
        return false
    end
end

-- Function to get hash from closest object
local function getHashFromClosest()
    if #harvestableObjects == 0 then
        findHarvestableObjects()
    end
    
    if #harvestableObjects == 0 then
        statusLabel.Text = "Status: No objects to get hash from!"
        return
    end
    
    -- Update distances
    local player = game:GetService("Players").LocalPlayer
    local character = player.Character
    local playerPos = character and character.PrimaryPart and character.PrimaryPart.Position or Vector3.new(0, 0, 0)
    
    for _, obj in ipairs(harvestableObjects) do
        if obj.model and obj.model:IsDescendantOf(workspace) then
            local objPos = obj.position
            obj.distance = getDistance(playerPos, objPos)
        end
    end
    
    table.sort(harvestableObjects, function(a, b)
        return a.distance < b.distance
    end)
    
    local closest = harvestableObjects[1]
    if closest then
        -- Try multiple methods to get hash
        local foundHash = extractHashFromCrop(closest.model)
        
        if foundHash then
            currentCropHash = foundHash
            offsetLabel.Text = "Hash Offset: " .. foundHash:sub(1, 50) .. "..."
            statusLabel.Text = "Status: Extracted hash from " .. closest.name
            hashStatusLabel.Text = "Hash Status: New hash extracted: " .. foundHash:sub(1, 30)
            print("Extracted hash:", foundHash)
        else
            statusLabel.Text = "Status: Could not extract hash from " .. closest.name
            offsetLabel.Text = "Hash Offset: None found"
        end
    end
end

-- Function to harvest closest object
local function harvestClosest(useHashFromObject)
    if #harvestableObjects == 0 then
        findHarvestableObjects()
    end
    
    if #harvestableObjects == 0 then
        statusLabel.Text = "Status: No objects to harvest!"
        return
    end
    
    -- Update distances
    local player = game:GetService("Players").LocalPlayer
    local character = player.Character
    local playerPos = character and character.PrimaryPart and character.PrimaryPart.Position or Vector3.new(0, 0, 0)
    
    for _, obj in ipairs(harvestableObjects) do
        if obj.model and obj.model:IsDescendantOf(workspace) then
            local objPos = obj.position
            obj.distance = getDistance(playerPos, objPos)
        end
    end
    
    table.sort(harvestableObjects, function(a, b)
        return a.distance < b.distance
    end)
    
    local closest = harvestableObjects[1]
    if closest and closest.distance ~= math.huge then
        if useHashFromObject and closest.hash then
            harvestObject(closest, true, closest.hash)
        else
            harvestObject(closest, false)
        end
    else
        statusLabel.Text = "Status: No valid objects found nearby!"
    end
end

-- Function to harvest all objects
local function harvestAll(useObjectHashes)
    if #harvestableObjects == 0 then
        findHarvestableObjects()
    end
    
    if #harvestableObjects == 0 then
        statusLabel.Text = "Status: No objects to harvest!"
        return
    end
    
    harvestedCount = 0
    statusLabel.Text = "Status: Harvesting all " .. #harvestableObjects .. " objects..."
    
    for i, obj in ipairs(harvestableObjects) do
        if obj.model and obj.model:IsDescendantOf(workspace) then
            if useObjectHashes and obj.hash then
                harvestObject(obj, true, obj.hash)
            else
                harvestObject(obj, false)
            end
            task.wait(0.01) -- 0.01 second wait
        end
    end
    
    statusLabel.Text = "Status: Finished harvesting all objects (Total: " .. harvestedCount .. ")"
    findHarvestableObjects() -- Refresh list
end

