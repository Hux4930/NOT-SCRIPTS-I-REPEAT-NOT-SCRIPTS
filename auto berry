-- Variables
local capturedOffset = nil
local isCapturing = false
local harvestRemote = nil
local originalInvoke = nil

-- Safe string function
local function safeString(value)
    if value == nil then return "" end
    return tostring(value)
end

-- Find the harvest remote
local function findHarvestRemote()
    local rs = ReplicatedStorage
    local path = rs:FindFirstChild("rbxts_include")
    if path then
        path = path:FindFirstChild("node_modules")
        if path then
            path = path:FindFirstChild("@rbxts")
            if path then
                path = path:FindFirstChild("net")
                if path then
                    path = path:FindFirstChild("out")
                    if path then
                        path = path:FindFirstChild("_NetManaged")
                        if path then
                            local remote = path:FindFirstChild("CLIENT_HARVEST_CROP_REQUEST")
                            if remote then return remote end
                        end
                    end
                end
            end
        end
    end
    return nil
end

-- Start capture mode - hooks the remote to grab the offset when you manually harvest
local function startCapture()
    if isCapturing then
        statusLabel.Text = "Status: Already in capture mode! Go harvest a bush."
        return
    end
    
    harvestRemote = findHarvestRemote()
    if not harvestRemote then
        statusLabel.Text = "Status: ERROR - Cannot find harvest remote!"
        return
    end
    
    -- Save original function
    originalInvoke = harvestRemote.InvokeServer
    
    -- Hook the remote
    harvestRemote.InvokeServer = function(self, data)
        -- Capture the offset from the manual harvest
        if data and data["dZnpyRtxna"] then
            capturedOffset = data["dZnpyRtxna"]
            
            -- Show the captured offset
            local display = capturedOffset:gsub("[%z%c]", function(c)
                return string.format("\\x%02X", string.byte(c))
            end)
            offsetDisplay.Text = "Captured Offset: " .. display:sub(1, 80) .. "\n✓ Ready to auto harvest!"
            statusLabel.Text = "Status: ✓ OFFSET CAPTURED! You can now auto harvest."
            
            isCapturing = false
            
            -- Restore original function
            harvestRemote.InvokeServer = originalInvoke
            
            print("=== OFFSET CAPTURED ===")
            print("Offset:", capturedOffset)
            print("======================")
        end
        
        -- Call original
        return originalInvoke(self, data)
    end
    
    isCapturing = true
    statusLabel.Text = "Status: CAPTURE MODE - Manually harvest a berry bush NOW!"
    offsetDisplay.Text = "Captured Offset: WAITING...\nGo manually harvest a berry bush!"
end

-- Reset captured offset
local function resetOffset()
    capturedOffset = nil
    if isCapturing and harvestRemote and originalInvoke then
        harvestRemote.InvokeServer = originalInvoke
    end
    isCapturing = false
    offsetDisplay.Text = "Captured Offset: None\nClick START CAPTURE then manually harvest"
    statusLabel.Text = "Status: Offset reset. Click START CAPTURE to capture new offset."
end

-- Find all berry bushes (FIXED - no number errors)
local function findAllBushes()
    local bushes = {}
    local character = LocalPlayer.Character
    local playerPos = character and character.PrimaryPart and character.PrimaryPart.Position or Vector3.new(0, 0, 0)
    
    for _, island in pairs(Workspace.Islands:GetChildren()) do
        local blocks = island:FindFirstChild("Blocks")
        if blocks then
            for _, block in pairs(blocks:GetChildren()) do
                local blockName = safeString(block.Name)
                local lowerName = blockName:lower()
                
                -- Check for berry bushes
                if lowerName:find("berry") or lowerName:find("bush") then
                    -- Get position safely
                    local blockPos = nil
                    if block:IsA("BasePart") then
                        blockPos = block.Position
                    elseif block:FindFirstChild("Position") and block.Position:IsA("BasePart") then
                        blockPos = block.Position.Position
                    else
                        blockPos = Vector3.new(0, 0, 0)
                    end
                    
                    local distance = (playerPos - blockPos).Magnitude
                    
                    table.insert(bushes, {
                        bush = block,
                        name = blockName,
                        position = blockPos,
                        distance = distance
                    })
                end
            end
        end
    end
    
    -- Sort by distance
    table.sort(bushes, function(a, b) return a.distance < b.distance end)
    
    return bushes
end

-- Refresh and display bush list
local function refreshBushList()
    local bushes = findAllBushes()
    local closeCount = 0
    
    for _, bush in ipairs(bushes) do
        if bush.distance <= 40 then
            closeCount = closeCount + 1
        end
    end
    
    bushCountLabel.Text = string.format("Bushes found: %d total, %d within 40 studs", #bushes, closeCount)
    
    if #bushes > 0 then
        statusLabel.Text = string.format("Status: Found %d bushes. Closest: %s (%.0f studs)", 
            #bushes, bushes[1].name, bushes[1].distance)
    else
        statusLabel.Text = "Status: No berry bushes found nearby!"
    end
    
    return bushes
end

-- Harvest a specific bush
local function harvestBush(bushData)
    if not capturedOffset then
        statusLabel.Text = "Status: No offset! Click START CAPTURE and manually harvest first!"
        return false
    end
    
    local remote = findHarvestRemote()
    if not remote then
        statusLabel.Text = "Status: Cannot find harvest remote!"
        return false
    end
    
    statusLabel.Text = "Status: Harvesting " .. bushData.name .. " (" .. string.format("%.0f", bushData.distance) .. " studs)"
    
    local success, err = pcall(function()
        return remote:InvokeServer({
            ["dZnpyRtxna"] = capturedOffset,
            ["player"] = LocalPlayer,
            ["model"] = bushData.bush,
        })
    end)
    
    if success then
        statusLabel.Text = "Status: ✓ Harvested " .. bushData.name
        return true
    else
        statusLabel.Text = "Status: Failed - " .. safeString(err):sub(1, 50)
        return false
    end
end

-- Harvest closest bush within 40 studs
local function harvestClosest()
    if not capturedOffset then
        statusLabel.Text = "Status: No offset! Click START CAPTURE and manually harvest first!"
        return
    end
    
    local bushes = findAllBushes()
    
    if #bushes == 0 then
        statusLabel.Text = "Status: No berry bushes found!"
        return
    end
    
    -- Find first bush within 40 studs
    local targetBush = nil
    for _, bush in ipairs(bushes) do
        if bush.distance <= 40 then
            targetBush = bush
            break
        end
    end
    
    if targetBush then
        harvestBush(targetBush)
        task.wait(0.5)
        refreshBushList() -- Refresh after harvest
    else
        statusLabel.Text = string.format("Status: No bushes within 40 studs! Closest is %.0f studs away.", bushes[1].distance)
    end
end

