-- Variables
local harvestableObjects = {}
local capturedHash = nil
local isLearning = false
local harvestRemote = nil
local originalRemote = nil

-- Find the harvest remote
local function findHarvestRemote()
    local replicatedStorage = game:GetService("ReplicatedStorage")
    local possiblePaths = {
        "rbxts_include.node_modules[@rbxts].net.out._NetManaged.CLIENT_HARVEST_CROP_REQUEST",
        "rbxts_include.node_modules.@rbxts.net.out._NetManaged.CLIENT_HARVEST_CROP_REQUEST",
        "CLIENT_HARVEST_CROP_REQUEST"
    }
    
    for _, path in ipairs(possiblePaths) do
        local remote = replicatedStorage:FindFirstChild(path)
        if remote then
            return remote
        end
    end
    
    -- Search recursively
    local function searchRecursive(parent, searchName)
        for _, child in ipairs(parent:GetChildren()) do
            if child.Name == searchName then
                return child
            end
            if child:IsA("Folder") or child:IsA("ModuleScript") then
                local found = searchRecursive(child, searchName)
                if found then return found end
            end
        end
        return nil
    end
    
    return searchRecursive(replicatedStorage, "CLIENT_HARVEST_CROP_REQUEST")
end

-- Hook into the remote to capture the hash when you manually harvest
local function hookRemoteForLearning()
    harvestRemote = findHarvestRemote()
    
    if not harvestRemote then
        statusLabel.Text = "Status: ERROR - Cannot find harvest remote!"
        return false
    end
    
    if not isLearning then
        -- Store original InvokeServer function
        originalRemote = harvestRemote.InvokeServer
        
        -- Hook the remote
        harvestRemote.InvokeServer = function(self, ...)
            local args = {...}
            local argTable = args[1]
            
            -- Capture the hash/offset
            if argTable and argTable["dZnpyRtxna"] then
                capturedHash = argTable["dZnpyRtxna"]
                hashLabel.Text = "Captured Hash: " .. capturedHash:gsub("[%z%c]", "\\x%02X"):sub(1, 100)
                statusLabel.Text = "Status: ✓ Hash captured successfully! Ready to auto-harvest."
                isLearning = false
                
                -- Unhook after capturing
                if originalRemote then
                    harvestRemote.InvokeServer = originalRemote
                end
                
                -- Play success sound
                        statusLabel.Text = "Status: Hash captured! You can now use auto harvest."
            end
            
            -- Call original function
            return originalRemote(self, ...)
        end
        
        return true
    end
    return false
end

-- Reset/Unhook the remote
local function unhookRemote()
    if harvestRemote and originalRemote then
        harvestRemote.InvokeServer = originalRemote
        originalRemote = nil
    end
    isLearning = false
end

-- Start learning mode
local function startLearning()
    if isLearning then
        statusLabel.Text = "Status: Already learning! Manually harvest a crop."
        return
    end
    
    unhookRemote()
    
    if hookRemoteForLearning() then
        isLearning = true
        statusLabel.Text = "Status: LEARNING MODE ACTIVE - Now manually harvest ONE crop!"
        hashLabel.Text = "Captured Hash: Waiting for manual harvest..."
        print("Learning mode active! Go manually harvest a crop to capture the hash.")
    else
        statusLabel.Text = "Status: Failed to hook remote! Check if game is loaded."
    end
end

-- Calculate distance
local function getDistance(pos1, pos2)
    return (pos1 - pos2).Magnitude
end

-- Find all harvestable objects
local function findHarvestableObjects()
    statusLabel.Text = "Status: Scanning for harvestable objects..."
    harvestableObjects = {}
    
    local player = game:GetService("Players").LocalPlayer
    local character = player.Character
    local playerPos = character and character.PrimaryPart and character.PrimaryPart.Position or Vector3.new(0, 0, 0)
    
    -- Scan islands
    for _, island in pairs(workspace.Islands:GetChildren()) do
        local blocks = island:FindFirstChild("Blocks")
        if blocks then
            for blockName, block in pairs(blocks:GetChildren()) do
                -- Check if it's a harvestable crop/bush/tree
                local isHarvestable = false
                local harvestType = "unknown"
                
                if blockName:lower():find("berry") or blockName:lower():find("bush") then
                    isHarvestable = true
                    harvestType = "berry"
                elseif blockName:lower():find("crop") or blockName:lower():find("wheat") or blockName:lower():find("carrot") or blockName:lower():find("potato") then
                    isHarvestable = true
                    harvestType = "crop"
                elseif blockName:lower():find("tree") or blockName:lower():find("wood") then
                    isHarvestable = true
                    harvestType = "tree"
                elseif block:IsA("Model") and (block:FindFirstChild("Harvestable") or block:GetAttribute("isHarvestable")) then
                    isHarvestable = true
                    harvestType = "other"
                end
                
                if isHarvestable then
                    local position = block:IsA("BasePart") and block.Position or 
                                   (block:FindFirstChild("Position") and block.Position.Position) or
                                   Vector3.new(0, 0, 0)
                    
                    local distance = getDistance(playerPos, position)
                    
                    table.insert(harvestableObjects, {
                        name = blockName,
                        model = block,
                        island = island,
                        position = position,
                        distance = distance,
                        type = harvestType
                    })
                end
            end
        end
    end
    
    -- Sort by distance
    table.sort(harvestableObjects, function(a, b) return a.distance < b.distance end)
    
    -- Update display
    local listText = "Found " .. #harvestableObjects .. " objects (sorted by distance):\n\n"
    for i, obj in ipairs(harvestableObjects) do
        listText = listText .. string.format("%d. %s [%s] - %.1f studs\n", i, obj.name, obj.type, obj.distance)
        if i >= 30 then
            listText = listText .. "... and " .. (#harvestableObjects - 30) .. " more"
            break
        end
    end
    
    listBox.Text = listText
    statusLabel.Text = "Status: Found " .. #harvestableObjects .. " harvestable objects"
    
    if #harvestableObjects == 0 then
        listBox.Text = "No harvestable objects found!\n\nMake sure you're near crops/berry bushes."
    end
end

-- Harvest a specific object
local function harvestObject(obj)
    if not obj or not obj.model then
        statusLabel.Text = "Status: Invalid object!"
        return false
    end
    
    if not capturedHash then
        statusLabel.Text = "Status: No hash captured! Click 'Start Learning' and manually harvest first."
        return false
    end
    
    local player = game:GetService("Players").LocalPlayer
    local remote = findHarvestRemote()
    
    if not remote then
        statusLabel.Text = "Status: Cannot find harvest remote!"
        return false
    end
    
    statusLabel.Text = "Status: Harvesting " .. obj.name
    
    local success, result = pcall(function()
        return remote:InvokeServer({
            ["dZnpyRtxna"] = capturedHash,
            ["player"] = player,
            ["model"] = obj.model,
        })
    end)
    
    if success then
        statusLabel.Text = "Status: ✓ Harvested " .. obj.name
        print("Harvested:", obj.name, "at distance:", obj.distance)
        return true
    else
        statusLabel.Text = "Status: ✗ Failed to harvest " .. obj.name
        warn("Harvest failed:", result)
        return false
    end
end

-- Harvest closest object
local function harvestClosest()
    if #harvestableObjects == 0 then
        findHarvestableObjects()
    end
    
    if #harvestableObjects == 0 then
        statusLabel.Text = "Status: No objects to harvest!"
        return
    end
    
    if not capturedHash then
        statusLabel.Text = "Status: No hash! Click 'Start Learning' and manually harvest first."
        return
    end
    
    -- Update distances
    local player = game:GetService("Players").LocalPlayer
    local character = player.Character
    local playerPos = character and character.PrimaryPart and character.PrimaryPart.Position or Vector3.new(0, 0, 0)
    
    for _, obj in ipairs(harvestableObjects) do
        if obj.model and obj.model:IsDescendantOf(workspace) then
            obj.distance = getDistance(playerPos, obj.position)
        end
    end
    
    table.sort(harvestableObjects, function(a, b) return a.distance < b.distance end)
    
    local closest = harvestableObjects[1]
    if closest then
        harvestObject(closest)
    else
        statusLabel.Text = "Status: No valid objects nearby!"
    end
end

-- Harvest all objects
local function harvestAll()
    if #harvestableObjects == 0 then
        findHarvestableObjects()
    end
    
    if #harvestableObjects == 0 then
        statusLabel.Text = "Status: No objects to harvest!"
        return
    end
    
    if not capturedHash then
        statusLabel.Text = "Status: No hash! Click 'Start Learning' and manually harvest first."
        return
    end
    
    statusLabel.Text = "Status: Harvesting all " .. #harvestableObjects .. " objects..."
    
    local successCount = 0
    for i, obj in ipairs(harvestableObjects) do
        if obj.model and obj.model:IsDescendantOf(workspace) then
            if harvestObject(obj) then
                successCount = successCount + 1
            end
            task.wait(0.01) -- 0.01 second wait
        end
    end
    
    statusLabel.Text = string.format("Status: Complete! Harvested %d/%d objects", successCount, #harvestableObjects)
    findHarvestableObjects() -- Refresh list
end

