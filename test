local function updateBlocksStatus()
	local counts = {}
	local total  = 0
	for _, child in ipairs(cloneFolder:GetChildren()) do
		if child:IsA("BasePart") and child.Name ~= "PrimaryPart" then
			local name = child.Name
			counts[name] = (counts[name] or 0) + 1
			total = total + 1
		end
	end
	if total == 0 then BlocksStatus:SetDesc("no preview loaded"); return end
	local sorted = {}
	for name in pairs(counts) do table.insert(sorted, name) end
	table.sort(sorted)
	local lines = { string.format("Total: %d blocks", total), "" }
	for _, name in ipairs(sorted) do
		table.insert(lines, string.format("%s: %d", name, counts[name]))
	end
	BlocksStatus:SetDesc(table.concat(lines, "\n"))
end

local function updateSelectionStatus()
	local startPos = selectionStartPos or (selectionStartBlock and selectionStartBlock.Position)
	local endPos   = selectionEndPos   or (selectionEndBlock   and selectionEndBlock.Position)
	if not startPos or not endPos then
		SelectionStatus:SetDesc("pick a start and end block, or use step buttons")
		return
	end
	local minX = math.min(startPos.X, endPos.X)
	local minY = math.min(startPos.Y, endPos.Y)
	local minZ = math.min(startPos.Z, endPos.Z)
	local maxX = math.max(startPos.X, endPos.X)
	local maxY = math.max(startPos.Y, endPos.Y)
	local maxZ = math.max(startPos.Z, endPos.Z)
	local sizeX = ((maxX - minX) / BLOCK_SIZE) + 1
	local sizeY = ((maxY - minY) / BLOCK_SIZE) + 1
	local sizeZ = ((maxZ - minZ) / BLOCK_SIZE) + 1
	SelectionStatus:SetDesc(string.format(
		"Start: (%d, %d, %d)\nEnd:   (%d, %d, %d)\nSize:  %dx%dx%d  (%d cells)",
		startPos.X, startPos.Y, startPos.Z,
		endPos.X, endPos.Y, endPos.Z,
		sizeX, sizeY, sizeZ, sizeX * sizeY * sizeZ
	))
end

local function rebuildSelectionPart()
	local startPos = selectionStartPos or (selectionStartBlock and selectionStartBlock.Position)
	local endPos   = selectionEndPos   or (selectionEndBlock   and selectionEndBlock.Position)
	if not startPos or not endPos then return end

	local minX = math.min(startPos.X, endPos.X)
	local minY = math.min(startPos.Y, endPos.Y)
	local minZ = math.min(startPos.Z, endPos.Z)
	local maxX = math.max(startPos.X, endPos.X)
	local maxY = math.max(startPos.Y, endPos.Y)
	local maxZ = math.max(startPos.Z, endPos.Z)

	local size   = Vector3.new((maxX - minX) + BLOCK_SIZE, (maxY - minY) + BLOCK_SIZE, (maxZ - minZ) + BLOCK_SIZE)
	local center = Vector3.new((minX + maxX) / 2, (minY + maxY) / 2, (minZ + maxZ) / 2)

	if not selectionPart then
		selectionPart             = Instance.new("Part")
		selectionPart.Name        = SELECTION_PART_NAME
		selectionPart.Anchored    = true
		selectionPart.CanCollide  = false
		selectionPart.CastShadow  = false
		selectionPart.Material    = Enum.Material.Neon
		selectionPart.Color       = Color3.fromRGB(75, 170, 255)
		selectionPart.Transparency = 0.8
		selectionPart.Parent      = Workspace
		local box = Instance.new("SelectionBox")
		box.LineThickness       = 0.05
		box.Color3              = Color3.fromRGB(75, 170, 255)
		box.SurfaceTransparency = 1
		box.Adornee             = selectionPart
		box.Parent              = selectionPart
	end

	selectionPart.Size   = size
	selectionPart.CFrame = CFrame.new(center)

	if not startMarker then startMarker = createMarker(START_MARKER_NAME, Color3.fromRGB(70, 170, 255)) end
	startMarker.CFrame = CFrame.new(startPos)

	if not endMarker then endMarker = createMarker(END_MARKER_NAME, Color3.fromRGB(255, 95, 95)) end
	endMarker.CFrame = CFrame.new(endPos)

	updateSelectionStatus()
end

local function moveCorner(corner, dx, dy, dz)
	local step = selectionMoveStep * BLOCK_SIZE
	if corner == "start" then
		local pos = selectionStartPos or (selectionStartBlock and selectionStartBlock.Position) or Vector3.new(0, 0, 0)
		selectionStartPos   = pos + Vector3.new(dx * step, dy * step, dz * step)
		selectionStartBlock = nil
		if not startMarker then startMarker = createMarker(START_MARKER_NAME, Color3.fromRGB(70, 170, 255)) end
		startMarker.CFrame = CFrame.new(selectionStartPos)
	else
		local pos = selectionEndPos or (selectionEndBlock and selectionEndBlock.Position) or Vector3.new(0, 0, 0)
		selectionEndPos   = pos + Vector3.new(dx * step, dy * step, dz * step)
		selectionEndBlock = nil
		if not endMarker then endMarker = createMarker(END_MARKER_NAME, Color3.fromRGB(255, 95, 95)) end
		endMarker.CFrame = CFrame.new(selectionEndPos)
	end
	rebuildSelectionPart()
end

local function isPreviewBlock(block)
	return block
		and block.Parent == cloneFolder
		and block:IsA("BasePart")
		and block.Name ~= "PrimaryPart"
end

local function clearPreview()
	local removed = 0
	for _, child in ipairs(cloneFolder:GetChildren()) do
		child:Destroy()
		removed = removed + 1
		if removed % 100 == 0 then task.wait() end
	end
	cloneFolder.PrimaryPart = nil
	previewRotationDeg      = 0
	updatePreviewStatus()
	updateRotateStatus()
	updateBlocksStatus()
end

local function getPreviewBlocks()
	local blocks = {}
	for _, child in ipairs(cloneFolder:GetChildren()) do
		if isPreviewBlock(child) then table.insert(blocks, child) end
	end
	return blocks
end

local function refreshPreviewStackKeys()
	for _, block in ipairs(getPreviewBlocks()) do
		block:SetAttribute("StackPositionKey", getPositionOnlyKey(block.CFrame.Position))
	end
end

local function getPartAabb(part)
	local half = part.Size / 2
	local corners = {
		Vector3.new(-half.X, -half.Y, -half.Z),
		Vector3.new(-half.X, -half.Y,  half.Z),
		Vector3.new(-half.X,  half.Y, -half.Z),
		Vector3.new(-half.X,  half.Y,  half.Z),
		Vector3.new( half.X, -half.Y, -half.Z),
		Vector3.new( half.X, -half.Y,  half.Z),
		Vector3.new( half.X,  half.Y, -half.Z),
		Vector3.new( half.X,  half.Y,  half.Z)
	}

	local minX, minY, minZ = math.huge, math.huge, math.huge
	local maxX, maxY, maxZ = -math.huge, -math.huge, -math.huge
	for _, corner in ipairs(corners) do
		local point = part.CFrame:PointToWorldSpace(corner)
		if point.X < minX then minX = point.X end
		if point.Y < minY then minY = point.Y end
		if point.Z < minZ then minZ = point.Z end
		if point.X > maxX then maxX = point.X end
		if point.Y > maxY then maxY = point.Y end
		if point.Z > maxZ then maxZ = point.Z end
	end
	return Vector3.new(minX, minY, minZ), Vector3.new(maxX, maxY, maxZ)
end

local function getPreviewBounds()
	local blocks = getPreviewBlocks()
	if #blocks == 0 then return nil end
	local minX, minY, minZ = math.huge, math.huge, math.huge
	local maxX, maxY, maxZ = -math.huge, -math.huge, -math.huge

	local function includePart(part)
		local partMin, partMax = getPartAabb(part)
		if partMin.X < minX then minX = partMin.X end
		if partMin.Y < minY then minY = partMin.Y end
		if partMin.Z < minZ then minZ = partMin.Z end
		if partMax.X > maxX then maxX = partMax.X end
		if partMax.Y > maxY then maxY = partMax.Y end
		if partMax.Z > maxZ then maxZ = partMax.Z end
	end

	for _, block in ipairs(blocks) do
		includePart(block)
		for _, child in ipairs(block:GetChildren()) do
			if child:IsA("BasePart") and child:GetAttribute("IsPreviewHitbox") == true then
				includePart(child)
			end
		end
	end
	return Vector3.new((minX + maxX) / 2, (minY + maxY) / 2, (minZ + maxZ) / 2),
		Vector3.new(maxX - minX, maxY - minY, maxZ - minZ)
end

updatePreviewDragPart = function()
	if previewDragFolder and not previewDragFolder:IsA("Folder") then
		previewDragFolder:Destroy()
		previewDragFolder = nil
		previewDragHandles = {}
	end
	if not previewDragFolder then
		previewDragFolder = Instance.new("Folder")
		previewDragFolder.Name = PREVIEW_DRAGGER_NAME
		previewDragFolder.Parent = Workspace
	end
	if next(previewDragHandles) == nil then
		for _, child in ipairs(previewDragFolder:GetChildren()) do
			child:Destroy()
		end
	end

	if not dragPreviewEnabled then
		for _, handle in pairs(previewDragHandles) do
			handle.line.Transparency = 1
			handle.knob.Transparency = 1
		end
		DragStatus:SetDesc("off")
		return
	end

	local center, size = getPreviewBounds()
	if not center then
		for _, handle in pairs(previewDragHandles) do
			handle.line.Transparency = 1
			handle.knob.Transparency = 1
		end
		DragStatus:SetDesc("load a preview, then drag an arrow handle")
		return
	end

	local maxExtent = math.max(size.X, size.Y, size.Z)
	local handleLength = math.max(BLOCK_SIZE * 4, (maxExtent / 2) + (BLOCK_SIZE * 3))
	local knobSize = BLOCK_SIZE * 0.8
	local configs = {
		Right = { axis = Vector3.new(1, 0, 0), color = Color3.fromRGB(255, 90, 90), lineSize = Vector3.new(handleLength, 0.35, 0.35), angle = CFrame.new() },
		Left = { axis = Vector3.new(-1, 0, 0), color = Color3.fromRGB(255, 90, 90), lineSize = Vector3.new(handleLength, 0.35, 0.35), angle = CFrame.new() },
		Up = { axis = Vector3.new(0, 1, 0), color = Color3.fromRGB(90, 255, 120), lineSize = Vector3.new(0.35, handleLength, 0.35), angle = CFrame.new() },
		Down = { axis = Vector3.new(0, -1, 0), color = Color3.fromRGB(90, 255, 120), lineSize = Vector3.new(0.35, handleLength, 0.35), angle = CFrame.new() },
		Forward = { axis = Vector3.new(0, 0, 1), color = Color3.fromRGB(90, 170, 255), lineSize = Vector3.new(0.35, 0.35, handleLength), angle = CFrame.new() },
		Back = { axis = Vector3.new(0, 0, -1), color = Color3.fromRGB(90, 170, 255), lineSize = Vector3.new(0.35, 0.35, handleLength), angle = CFrame.new() },
	}

	for name, config in pairs(configs) do
		local handle = previewDragHandles[name]
		if not handle then
			local line = Instance.new("Part")
			line.Name = "DragLine" .. name
			line.Anchored = true
			line.CanCollide = false
			line.CastShadow = false
			line.Material = Enum.Material.Neon
			line.Parent = previewDragFolder

			local knob = Instance.new("Part")
			knob.Name = "DragHandle" .. name
			knob.Anchored = true
			knob.CanCollide = false
			knob.CastShadow = false
			knob.Material = Enum.Material.ForceField
			knob.Shape = Enum.PartType.Ball
			knob.Parent = previewDragFolder

			handle = { line = line, knob = knob, axis = config.axis }
			previewDragHandles[name] = handle
		end

		local lineCenter = center + config.axis * (handleLength / 2)
		local knobCenter = center + config.axis * handleLength
		handle.axis = config.axis
		handle.line.Size = config.lineSize
		handle.line.CFrame = CFrame.new(lineCenter)
		handle.line.Color = config.color
		handle.line.Transparency = 0.15
		handle.knob.Size = Vector3.new(knobSize, knobSize, knobSize)
		handle.knob.CFrame = CFrame.new(knobCenter)
		handle.knob.Color = config.color
		handle.knob.Transparency = 0.2
	end
	DragStatus:SetDesc("drag a direction handle; movement snaps every 3 studs")
end

local function ensurePreviewPrimaryPart()
	if cloneFolder.PrimaryPart and cloneFolder.PrimaryPart.Parent == cloneFolder then
		return cloneFolder.PrimaryPart
	end
	for _, child in ipairs(cloneFolder:GetChildren()) do
		if isPreviewBlock(child) then cloneFolder.PrimaryPart = child; return child end
	end
	return nil
end

-- (movement is now world-axis; see movePreviewByBlocks below)

local function movePreviewByBlocks(xBlocks, yBlocks, zBlocks)
	-- Move the ENTIRE preview group by a fixed world-axis offset (like Roblox Studio's
	-- Move tool with grid snap).  Always X=right, Y=up, Z=forward — never camera-relative.
	local blocks = getPreviewBlocks()
	if #blocks == 0 then notify("Preview", "Load or copy a preview first.", 3); return false end

	local offset = Vector3.new(
		(tonumber(xBlocks) or 0) * BLOCK_SIZE,
		(tonumber(yBlocks) or 0) * BLOCK_SIZE,
		(tonumber(zBlocks) or 0) * BLOCK_SIZE
	)

	for _, b in ipairs(blocks) do
		b.CFrame = b.CFrame + offset
	end

	-- Keep PrimaryPart in sync so future operations still have a reference
	local primary = ensurePreviewPrimaryPart()
	if primary then cloneFolder.PrimaryPart = primary end

	refreshPreviewStackKeys()
	updatePreviewStatus()
	return true
end

-- ─── Rotation & Flip ──────────────────────────────────────────────────────────
--[[
	Rotation is always around the Y-axis (vertical), using the bounding-box
	centre of the preview as the pivot.  Flip X and Flip Z mirror the preview
	across those axes through the same centre pivot.

	All operations work by repositioning and reorienting every block CFrame
	relative to the pivot; no model-level SetPrimaryPartCFrame tricks are needed
	so the preview stays grid-aligned after each operation.
]]

-- (centre is computed inline inside applyTransformToPreview)

--[[
	ROTATION FIX:
	All block positions are multiples of BLOCK_SIZE.  The bounding-box centre
	may land at a half-block offset when the build has an even number of blocks
	on an axis (e.g. two blocks at X=0 and X=3 → centre X=1.5).

	Strategy that always keeps blocks on-grid and touching:
	  1. Express every block as an integer grid-coordinate (pos / BLOCK_SIZE).
	  2. Compute the centre in grid-coords (may be fractional .5 for even widths).
	  3. Translate so the grid-coord centre is at the origin.
	  4. Apply the integer rotation (cos/sin of 90° multiples are exactly 0 or ±1).
	  5. Translate back and convert to world studs.

	Because we only support 90° steps the rotation matrix entries are integers,
	so no floating-point drift ever accumulates.  For flips the same logic holds.
]]

local function applyTransformToPreview(transformGridFn, rotationDelta)
	-- transformGridFn: receives (gx, gy, gz) integer grid coords relative to
	-- the grid centre, returns (nx, ny, nz) new grid coords (also integers).
	local blocks = getPreviewBlocks()
	if #blocks == 0 then notify("Rotate", "Load a preview first.", 3); return end

	-- Collect grid coordinates
	local gcoords = {}
	local minGX, minGY, minGZ =  math.huge,  math.huge,  math.huge
	local maxGX, maxGY, maxGZ = -math.huge, -math.huge, -math.huge
	for _, b in ipairs(blocks) do
		local gx = math.round(b.Position.X / BLOCK_SIZE)
		local gy = math.round(b.Position.Y / BLOCK_SIZE)
		local gz = math.round(b.Position.Z / BLOCK_SIZE)
		table.insert(gcoords, { block = b, gx = gx, gy = gy, gz = gz, rotation = b.CFrame - b.Position })
		if gx < minGX then minGX = gx end
		if gy < minGY then minGY = gy end
		if gz < minGZ then minGZ = gz end
		if gx > maxGX then maxGX = gx end
		if gy > maxGY then maxGY = gy end
		if gz > maxGZ then maxGZ = gz end
	end

	-- Centre in grid-space (may be .5 for even-width builds — that's fine)
	local cx = (minGX + maxGX) / 2
	local cy = (minGY + maxGY) / 2
	local cz = (minGZ + maxGZ) / 2

	-- Transform each block
	for _, entry in ipairs(gcoords) do
		-- relative grid coords (floating for even builds)
		local rx = entry.gx - cx
		local ry = entry.gy - cy
		local rz = entry.gz - cz

		local nx, ny, nz = transformGridFn(rx, ry, rz)

		-- New absolute grid coord, rounded back to integer (handles .5 centres)
		local newGX = math.round(cx + nx)
		local newGY = math.round(cy + ny)
		local newGZ = math.round(cz + nz)

		local newPosition = Vector3.new(newGX * BLOCK_SIZE, newGY * BLOCK_SIZE, newGZ * BLOCK_SIZE)
		local newRotation = entry.rotation
		if rotationDelta then
			newRotation = rotationDelta * newRotation
		end
		entry.block.CFrame = CFrame.new(newPosition) * newRotation
	end

	refreshPreviewStackKeys()
	updatePreviewStatus()
	updateBlocksStatus()
	updatePreviewDragPart()
end

local function rotatePreviewY(angleDeg)
	-- For 90° multiples: cos/sin are exactly 0 or ±1 — no float error.
	local rad       = math.rad(angleDeg)
	local cosA      = math.round(math.cos(rad))   -- -1, 0, or 1
	local sinA      = math.round(math.sin(rad))   -- -1, 0, or 1

	applyTransformToPreview(function(rx, ry, rz)
		-- Standard Y-axis rotation (clockwise = positive angle)
		return cosA * rx + sinA * rz,
		       ry,
		       -sinA * rx + cosA * rz
	end, CFrame.Angles(0, rad, 0))

	previewRotationDeg = (previewRotationDeg + angleDeg) % 360
	updateRotateStatus()
	notify("Rotate", string.format("Rotated to %d°", previewRotationDeg), 2)
end

local function flipPreviewX()
	applyTransformToPreview(function(rx, ry, rz) return -rx, ry, rz end)
	notify("Rotate", "Flipped on X axis.", 2)
end

local function flipPreviewZ()
	applyTransformToPreview(function(rx, ry, rz) return rx, ry, -rz end)
	notify("Rotate", "Flipped on Z axis.", 2)
end

local function flipPreviewY()
	applyTransformToPreview(function(rx, ry, rz) return rx, -ry, rz end)
	notify("Rotate", "Flipped vertically (Y axis).", 2)
end

-- ─── Selection blocks ─────────────────────────────────────────────────────────

local function getSelectionBlocks()
	if not selectionPart then return nil, "Pick a start and end block first." end
	local blocks = {}
	local island = getLocalIsland()
	local blocksContainer = island and island:FindFirstChild("Blocks")
	if not blocksContainer then return nil, "Could not find your island Blocks folder." end

	local center = selectionPart.Position
	local half = selectionPart.Size / 2
	local minPos = center - half - Vector3.new(0.01, 0.01, 0.01)
	local maxPos = center + half + Vector3.new(0.01, 0.01, 0.01)
	local seen = {}

	local function getBlockPart(block)
		if block:IsA("BasePart") then return block end
		if block:IsA("Model") then
			if block.PrimaryPart then return block.PrimaryPart end
			local root = block:FindFirstChild("Root")
			if root and root:IsA("BasePart") then return root end
		end
		return block:FindFirstChildWhichIsA("BasePart", true)
	end

	for _, block in ipairs(blocksContainer:GetChildren()) do
		local part = getBlockPart(block)
		if part then
			local pos = part.Position
			if pos.X >= minPos.X and pos.X <= maxPos.X
				and pos.Y >= minPos.Y and pos.Y <= maxPos.Y
				and pos.Z >= minPos.Z and pos.Z <= maxPos.Z
				and not seen[block]
			then
				seen[block] = true
				table.insert(blocks, {
					Name = block.Name,
					Position = pos,
					CFrame = part.CFrame,
					Instance = block,
					Part = part
				})
			end
		end
	end
	if #blocks == 0 then return nil, "No island blocks were found inside the selection." end
	return blocks
end

local function getSelectionOrigin(blocks)
	local minX, minY, minZ = math.huge, math.huge, math.huge
	for _, block in ipairs(blocks) do
		local pos = block.Position
		if pos.X < minX then minX = pos.X end
		if pos.Y < minY then minY = pos.Y end
		if pos.Z < minZ then minZ = pos.Z end
	end
	return Vector3.new(minX, minY, minZ)
end

local function buildSchematicData(blocks)
	local origin      = getSelectionOrigin(blocks)
	local originCFrame = CFrame.new(origin)
	local data = {
		FormatVersion = 2,
		BlockSize     = BLOCK_SIZE,
		Origin        = { origin.X, origin.Y, origin.Z },
		Blocks        = {}
	}

	table.sort(blocks, function(a, b)
		if a.Position.Y ~= b.Position.Y then return a.Position.Y < b.Position.Y end
		if a.Position.X ~= b.Position.X then return a.Position.X < b.Position.X end
		if a.Position.Z ~= b.Position.Z then return a.Position.Z < b.Position.Z end
		return a.Name < b.Name
	end)

	for _, block in ipairs(blocks) do
		local relative  = originCFrame:ToObjectSpace(block.CFrame)
		local blockName = block.Name
		if not data.Blocks[blockName] then data.Blocks[blockName] = {} end
		table.insert(data.Blocks[blockName], { C = { relative:GetComponents() } })
	end

	return data
end

local function stripComments(text)
	if type(text) ~= "string" then return nil end
	return text:gsub("%-%-.-\n", "\n")
end

local function decodeSchematicText(text)
	if type(text) ~= "string" or text == "" then return nil, "No schematic code was provided." end
	local cleaned = stripComments(text)
	local ok, decoded = pcall(function() return HttpService:JSONDecode(cleaned) end)
	if not ok then return nil, tostring(decoded) end
	return decoded, cleaned
end

local function normalizePreviewBlockName(name)
	if name == "dirt" then return "soil" end
	return name
end

local function normalizePlaceBlockName(name)
	if name == "soil" then return "grass" end
	return name
end

function setPartQueryFlags(part, canQuery, canTouch)
	pcall(function() part.CanQuery = canQuery end)
	pcall(function() part.CanTouch = canTouch end)
end

function getCollisionBoxParts(blockFolder)
	local collisionFolder = blockFolder and blockFolder:FindFirstChild("CollisionBoxes")
	if not collisionFolder then return {} end

	local parts = {}
	for _, child in ipairs(collisionFolder:GetDescendants()) do
		if child:IsA("BasePart") then
			table.insert(parts, child)
		end
	end
	return parts
end

function syncPreviewBlockCollision(previewBlock)
	if not previewBlock or not previewBlock:IsA("BasePart") then return end
	local hasHitboxes = previewBlock:GetAttribute("HasPreviewHitboxes") == true
	previewBlock.CanCollide = buildCollision and not hasHitboxes

	for _, child in ipairs(previewBlock:GetChildren()) do
		if child:IsA("BasePart") and child:GetAttribute("IsPreviewHitbox") == true then
			child.CanCollide = buildCollision
			setPartQueryFlags(child, true, buildCollision)
		end
	end
end

function attachPreviewCollisionBoxes(previewBlock, blockFolder, root, worldCFrame)
	local collisionParts = getCollisionBoxParts(blockFolder)
	if #collisionParts == 0 then return false end

	for _, sourceBox in ipairs(collisionParts) do
		local relative = root.CFrame:ToObjectSpace(sourceBox.CFrame)
		local hitbox = sourceBox:Clone()
		for _, descendant in ipairs(hitbox:GetDescendants()) do
			if descendant:IsA("WeldConstraint") or descendant:IsA("JointInstance") then
				descendant:Destroy()
			end
		end
		hitbox.Name = "Hitbox_" .. tostring(sourceBox.Name)
		hitbox.Anchored = false
		hitbox.Massless = true
		hitbox.Locked = false
		hitbox.CastShadow = false
		hitbox.Material = Enum.Material.ForceField
		hitbox.Color = Color3.fromRGB(255, 215, 90)
		hitbox.Transparency = math.max(0.35, math.min(0.85, hitbox.Transparency))
		hitbox.CFrame = worldCFrame:ToWorldSpace(relative)
		hitbox.Parent = previewBlock
		hitbox:SetAttribute("IsPreviewHitbox", true)
		setPartQueryFlags(hitbox, true, buildCollision)

		local weld = Instance.new("WeldConstraint")
		weld.Part0 = previewBlock
		weld.Part1 = hitbox
		weld.Parent = hitbox
	end

	previewBlock:SetAttribute("HasPreviewHitboxes", true)
	return true
end

getPositionOnlyKey = function(position)
	return string.format("%d:%d:%d",
		math.round(position.X * 1000),
		math.round(position.Y * 1000),
		math.round(position.Z * 1000)
	)
end

local function spawnPreviewBlock(blockName, worldCFrame)
	local previewName = normalizePreviewBlockName(blockName)
	local blockFolder = blocksFolder:FindFirstChild(previewName)
	if not blockFolder then warn("Preview block folder missing:", previewName); return nil end
	local root = blockFolder:FindFirstChild("Root")
	if not root then warn("Preview root missing:", previewName); return nil end

	local previewBlock             = root:Clone()
	previewBlock.Name              = previewName
	previewBlock.Anchored          = true
	previewBlock.CanCollide        = buildCollision
	previewBlock.Transparency      = 0.5
	previewBlock.Locked            = false
	previewBlock.Parent            = cloneFolder
	previewBlock.CFrame            = worldCFrame
	previewBlock:SetAttribute("StackPositionKey", getPositionOnlyKey(worldCFrame.Position))
	attachPreviewCollisionBoxes(previewBlock, blockFolder, root, worldCFrame)
	syncPreviewBlockCollision(previewBlock)
	return previewBlock
end

local function loadDecodedSchematic(decoded)
	if not decoded then return false, "No decoded schematic data." end
	clearPreview()
	cloneFolder.Parent = nil
	local placed = 0
	local processed = 0

	local function markPreviewLoaded()
		processed = processed + 1
		if processed % previewLoadYieldEvery == 0 then
			PreviewStatus:SetDesc(string.format("loading preview... %d block(s)", placed))
			task.wait()
		end
	end

	local decodedBlocks = decoded.Blocks or decoded.blocks
	if decodedBlocks then
		local origin = decoded.Origin or decoded.origin or { 0, 0, 0 }
		local originCFrame = CFrame.new(
			tonumber(origin[1]) or 0,
			tonumber(origin[2]) or 0,
			tonumber(origin[3]) or 0
		)
		for blockName, blockList in pairs(decodedBlocks) do
			for _, block in ipairs(blockList) do
				if block.C then
					local relative = CFrame.new(table.unpack(block.C))
					local world    = originCFrame:ToWorldSpace(relative)
					if spawnPreviewBlock(blockName, world) then placed = placed + 1 end
					markPreviewLoaded()
				end
			end
		end
	else
		for blockName, blockList in pairs(decoded) do
			for _, block in ipairs(blockList) do
				local x = tonumber(block[1]) or 0
				local y = tonumber(block[2]) or 0
				local z = tonumber(block[3]) or 0
				if spawnPreviewBlock(blockName, CFrame.new(x, y, z)) then placed = placed + 1 end
				markPreviewLoaded()
			end
		end
	end

	cloneFolder.Parent = Workspace
	updatePreviewStatus()
	updateBlocksStatus()
	if placed == 0 then return false, "No preview blocks could be loaded." end
	return true, placed
end

local function loadSchematicText(text)
	local decoded, cleanedOrError = decodeSchematicText(text)
	if not decoded then return false, cleanedOrError end
	lastSavedJson = cleanedOrError
	return loadDecodedSchematic(decoded)
end

function OnlineBuilds.GetGuiParent()
	local ok, hiddenGui = pcall(function()
		if type(gethui) == "function" then return gethui() end
	end)
	if ok and hiddenGui then return hiddenGui end

	local coreGui = game:GetService("CoreGui")
	local canUseCoreGui = pcall(function()
		local probe = Instance.new("Folder")
		probe.Parent = coreGui
		probe:Destroy()
	end)
	if canUseCoreGui then return coreGui end
	return LocalPlayer:WaitForChild("PlayerGui")
end

function OnlineBuilds.GetNames()
	local names = {}
	for name in pairs(OnlineBuilds.Entries) do table.insert(names, name) end
	table.sort(names, function(a, b) return a:lower() < b:lower() end)
	return names
end

function OnlineBuilds.NormalizeEntry(name, value)
	if type(value) == "table" and (value.Blocks or value.blocks) then
		return { name = tostring(name), data = value }
	end
	if type(value) == "string" then
		return { name = tostring(name), url = value }
	end
	if type(value) ~= "table" then return nil end

	local entryName = tostring(value.name or value.Name or value.title or value.Title or name)
	local entryData = value.data or value.Data or value.schematic or value.Schematic
	local entryUrl = value.url or value.URL or value.raw or value.Raw
	if type(entryData) == "table" and (entryData.Blocks or entryData.blocks) then
		return { name = entryName, data = entryData }
	end
	if type(entryUrl) == "string" and entryUrl ~= "" then
		return { name = entryName, url = entryUrl }
	end
	return nil
end

function OnlineBuilds.ParseManifest(text)
	local decoded, decodeError = decodeSchematicText(text)
	if not decoded then
		local entries = {}
		for line in tostring(text):gmatch("[^\r\n]+") do
			local name, url = line:match("^%s*([^|]+)%s*|%s*(https?://%S+)%s*$")
			if name and url then entries[name] = { name = name, url = url } end
		end
		if next(entries) then return entries end
		return nil, "The builds file is not valid JSON: " .. tostring(decodeError)
	end

	if decoded.Blocks or decoded.blocks then
		local name = decoded.Name or decoded.name
			or (decoded.Metadata and (decoded.Metadata.Name or decoded.Metadata.name))
			or "Remote Build"
		return { [tostring(name)] = { name = tostring(name), data = decoded } }
	end

	local source = decoded.builds or decoded.Builds or decoded
	local entries = {}
	if #source > 0 then
		for index, value in ipairs(source) do
			local fallbackName = "Build " .. tostring(index)
			local entry = OnlineBuilds.NormalizeEntry(fallbackName, value)
			if entry then entries[entry.name] = entry end
		end
	else
		for name, value in pairs(source) do
			local entry = OnlineBuilds.NormalizeEntry(name, value)
			if entry then entries[entry.name] = entry end
		end
	end

	if not next(entries) then
		return nil, "The builds manifest contains no usable build entries."
	end
	return entries
end

function OnlineBuilds.Refresh()
	OnlineBuilds.Status:SetDesc("downloading build list...")
	local ok, response = pcall(function() return game:HttpGet(OnlineBuilds.URL, true) end)
	if not ok then
		OnlineBuilds.Status:SetDesc("download failed")
		return false, tostring(response)
	end

	local entries, parseError = OnlineBuilds.ParseManifest(response)
	if not entries then
		OnlineBuilds.Entries = {}
		if OnlineBuilds.Dropdown then OnlineBuilds.Dropdown:SetValues({}) end
		OnlineBuilds.Status:SetDesc(tostring(parseError))
		return false, parseError
	end

	OnlineBuilds.Entries = entries
	local names = OnlineBuilds.GetNames()
	OnlineBuilds.Selected = names[1]
	if OnlineBuilds.Dropdown then
		OnlineBuilds.Dropdown:SetValues(names)
		pcall(function() OnlineBuilds.Dropdown:SetValue(OnlineBuilds.Selected) end)
	end
	OnlineBuilds.Status:SetDesc(string.format("%d build(s) available", #names))
	return true, #names
end

function OnlineBuilds.ResolveData(entry)
	if not entry then return nil, "Select an online build first." end
	if entry.data then return entry.data end
	if type(entry.url) ~= "string" or entry.url == "" then
		return nil, "This build has no data or URL."
	end

	local url = entry.url
	if not url:match("^https?://") then
		url = "https://raw.githubusercontent.com/Hux4930/NOT-SCRIPTS-I-REPEAT-NOT-SCRIPTS/refs/heads/main/"
			.. url:gsub("^/+", "")
	end
	url = url:gsub(" ", "%%20")
	local ok, response = pcall(function() return game:HttpGet(url, true) end)
	if not ok then return nil, tostring(response) end
	local decoded, decodeError = decodeSchematicText(response)
	if not decoded then return nil, decodeError end
	entry.data = decoded
	return decoded
end

function OnlineBuilds.PrepareClone(instance)
	local clone = instance:Clone()
	for _, descendant in ipairs(clone:GetDescendants()) do
		if descendant:IsA("Script") or descendant:IsA("LocalScript") then
			descendant:Destroy()
		elseif descendant:IsA("BasePart") then
			descendant.Anchored = true
			descendant.CanCollide = false
			descendant.CanTouch = false
			descendant.CanQuery = false
		end
	end
	if clone:IsA("BasePart") then
		clone.Anchored = true
		clone.CanCollide = false
		clone.CanTouch = false
		clone.CanQuery = false
	end
	return clone
end

function OnlineBuilds.FindTemplate(blockName)
	local buildDisplayFolder = ReplicatedStorage:FindFirstChild("Blocks")
	if not buildDisplayFolder then return nil end
	local normalized = normalizePreviewBlockName(blockName)
	return buildDisplayFolder:FindFirstChild(normalized)
		or buildDisplayFolder:FindFirstChild(blockName)
end

function OnlineBuilds.AddTemplate(displayModel, blockName, worldCFrame)
	local template = OnlineBuilds.FindTemplate(blockName)
	if not template then return false end

	if template:IsA("Model") then
		local clone = OnlineBuilds.PrepareClone(template)
		clone.Parent = displayModel
		clone:PivotTo(worldCFrame)
		return true
	end
	if template:IsA("BasePart") then
		local clone = OnlineBuilds.PrepareClone(template)
		clone.CFrame = worldCFrame
		clone.Parent = displayModel
		return true
	end

	local root = template:FindFirstChild("Root", true)
	if root and root:IsA("BasePart") then
		local clone = OnlineBuilds.PrepareClone(root)
		clone.Name = blockName
		clone.CFrame = worldCFrame
		clone.Parent = displayModel
		return true
	end
	return false
end

