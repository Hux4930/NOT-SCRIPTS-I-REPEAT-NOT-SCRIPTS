local function pastePreview()
	if pasteInProgress then notify("Paste", "A paste is already running.", 3); return end
	local previewBlocks = getPreviewBlocks()
	if #previewBlocks == 0 then notify("Paste", "Load or copy a preview first.", 3); return end

	local ok, err = resolvePlacementHash(false)
	if not ok then notify("Paste", tostring(err), 5); return end

	pasteInProgress = true
	pasteStepAction = nil

	task.spawn(function()
		local normalPending, stackedBatches = buildPasteQueues(previewBlocks)
		local stackedBatchesBySize, stackedSizes = groupStackedBatchesBySize(stackedBatches)
		local stackedTotal = countStackedEntries(stackedBatches)
		local total          = #previewBlocks
		local placed         = 0
		local noProgressLoops = 0

		setPasteStatus(string.format(
			"multi-place sizes: %d | multi-place cells: %d | normal blocks last: %d | stacked remotes: %d",
			#stackedSizes,
			#stackedBatches,
			#normalPending,
			stackedTotal
		))

		local function processStackedStage(batches, stageName)
			for batchIndex, stackedBatch in ipairs(batches) do
				if not pasteInProgress then break end
				local batchPlaced = 0
				setPasteStatus(string.format(
					"%s %d/%d (%s) ready; Next spawns %d remote task(s)",
					stageName,
					batchIndex,
					#batches,
					tostring(stackedBatch.gridKey or "cell"),
					#stackedBatch
				))
				notify("Paste", string.format("%s %d ready. Press Next to place it.", stageName, batchIndex), 4)

				while pasteInProgress do
					pasteWaitingForStep = true
					local action = waitForPasteStep()
					if action == "stop" then break end
					if action == "redo" then
						setPasteStatus(string.format(
							"%s %d/%d (%s) has not fired yet; press Next first",
							stageName,
							batchIndex,
							#batches,
							tostring(stackedBatch.gridKey or "cell")
						))
						continue
					end
					batchPlaced = runWithPasteRenderingPaused(function()
						return placeStackedBlockBatch(stackedBatch, freezeRenderingDuringPaste)
					end)
					task.wait()
					placed = placed + batchPlaced
					break
				end
				if not pasteInProgress then break end

				setPasteStatus(string.format(
					"%s %d/%d (%s) spawned %d remote task(s); press Next or Redo",
					stageName,
					batchIndex,
					#batches,
					tostring(stackedBatch.gridKey or "cell"),
					batchPlaced
				))
				notify("Paste", string.format("%s %d fired. Press Next or Redo.", stageName, batchIndex), 4)

				while pasteInProgress do
					pasteWaitingForStep = true
					local action = waitForPasteStep()
					if action == "redo" then
						batchPlaced = runWithPasteRenderingPaused(function()
							return placeStackedBlockBatch(stackedBatch, freezeRenderingDuringPaste)
						end)
						task.wait()
						setPasteStatus(string.format(
							"redid %s %d/%d (%s): spawned %d remote task(s); press Next",
							stageName,
							batchIndex,
							#batches,
							tostring(stackedBatch.gridKey or "cell"),
							batchPlaced
						))
					else
						removeSuccessfulPreviewBlocks(stackedBatch)
						break
					end
				end
			end
		end

		for _, stackSize in ipairs(stackedSizes) do
			if not pasteInProgress then break end
			local batches = stackedBatchesBySize[stackSize]
			local stageName = string.format("%d-placement", stackSize)
			setPasteStatus(string.format(
				"processing all %d-placement cells: %d cell(s)",
				stackSize,
				#batches
			))
			notify("Paste", string.format("Starting all %d-placement cells.", stackSize), 3)
			processStackedStage(batches, stageName)
		end

		while pasteInProgress and #normalPending > 0 do
			local humanoidRootPart = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
			if not humanoidRootPart then task.wait(0.5); continue end

			local batch = {}
			for index = #normalPending, 1, -1 do
				local entry = normalPending[index]
				local previewBlock = entry.block
				if not previewBlock or not previewBlock.Parent then
					table.remove(normalPending, index)
				else
					local distance = (previewBlock.Position - humanoidRootPart.Position).Magnitude
					if distance <= 90 then
						entry.pendingIndex = index
						table.insert(batch, entry)
						if #batch >= pasteBatchSize then break end
					end
				end
			end

			local batchPlaced = 0
			if #batch > 0 then
				batchPlaced = runWithPasteRenderingPaused(function()
					return placeBlockBatch(batch)
				end)
			end
			for _, entry in ipairs(batch) do
				if entry.success then
					if entry.block and entry.block.Parent then entry.block:Destroy() end
					table.remove(normalPending, entry.pendingIndex)
				end
			end
			placed = placed + batchPlaced

			if batchPlaced > 0 then
				noProgressLoops = 0
				updatePreviewStatus()
				updateBlocksStatus()
				setPasteStatus(string.format("normal placing: %d/%d done", placed, total))
				task.wait(0.05)
			else
				noProgressLoops = noProgressLoops + 1
				if noProgressLoops >= 10 then
					notify("Paste", "Move closer to the preview so more blocks are in range.", 4)
					noProgressLoops = 0
				end
				task.wait(0.75)
			end
		end

		local wasStopped = not pasteInProgress
		pasteInProgress = false
		pasteStepAction = nil
		pasteWaitingForStep = false
		updatePreviewStatus()
		updateBlocksStatus()

		if wasStopped then
			setPasteStatus("stopped")
			notify("Paste", string.format("Paste stopped after placing %d of %d blocks.", placed, total), 4)
		else
			setPasteStatus("done")
			notify("Paste", string.format("Finished placing %d blocks.", placed), 4)
			-- Auto-upgrade totems to match saved schematic levels (if TotemData present)
			autoUpgradeFromSchematicTotemData()
		end
	end)
end

