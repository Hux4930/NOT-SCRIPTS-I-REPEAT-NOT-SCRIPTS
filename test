local function loadPlacementCache()
	if not isfile(PLACE_CACHE_FILE) then return nil end
	local ok, decoded = pcall(function() return HttpService:JSONDecode(readfile(PLACE_CACHE_FILE)) end)
	if not ok or type(decoded) ~= "table" then return nil end
	if tonumber(decoded.placeVersion) ~= game.PlaceVersion then return nil end
	if type(decoded.hashName) ~= "string" or type(decoded.hashValue) ~= "string" then return nil end
	return decoded.hashName, decoded.hashValue
