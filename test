				else
					missing[blockName] = true
				end
			end
		end
	end

	if shown == 0 then
		screenGui:Destroy()
		OnlineBuilds.ViewerGui = nil
		return false, "No blocks could be displayed from ReplicatedStorage.Blocks."
	end

	local boundsCFrame, boundsSize = displayModel:GetBoundingBox()
	displayModel:PivotTo(CFrame.new(-boundsCFrame.Position) * displayModel:GetPivot())
	local target = Vector3.zero
	local radius = math.max(boundsSize.X, boundsSize.Y, boundsSize.Z, 6) * 1.35
	local yaw, pitch = math.rad(40), math.rad(22)

	local function updateCamera()
		pitch = math.clamp(pitch, math.rad(-80), math.rad(80))
		radius = math.clamp(radius, 3, 2000)
		local offset = Vector3.new(
			math.cos(pitch) * math.sin(yaw),
			math.sin(pitch),
			math.cos(pitch) * math.cos(yaw)
		) * radius
		camera.CFrame = CFrame.lookAt(target + offset, target)
	end
	updateCamera()

	local draggingView = false
	local lastMousePosition = nil
	viewport.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.MouseButton2 then
			draggingView = true
			lastMousePosition = input.Position
		end
	end)
	viewport.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.MouseButton2 then
			draggingView = false
			lastMousePosition = nil
		end
	end)
	table.insert(viewerConnections, UserInputService.InputChanged:Connect(function(input)
		if not screenGui.Parent then return end
		if draggingView and input.UserInputType == Enum.UserInputType.MouseMovement then
			local current = input.Position
			if lastMousePosition then
				local delta = current - lastMousePosition
				yaw = yaw - delta.X * 0.01
				pitch = pitch + delta.Y * 0.01
				updateCamera()
			end
			lastMousePosition = current
		elseif input.UserInputType == Enum.UserInputType.MouseWheel then
			local mouse = UserInputService:GetMouseLocation()
			local pos, size = viewport.AbsolutePosition, viewport.AbsoluteSize
			if mouse.X >= pos.X and mouse.X <= pos.X + size.X
				and mouse.Y >= pos.Y and mouse.Y <= pos.Y + size.Y then
				radius = radius * (input.Position.Z > 0 and 0.88 or 1.14)
				updateCamera()
			end
		end
	end))

	local draggingWindow = false
	local dragStart, frameStart
	header.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			draggingWindow = true
			dragStart = input.Position
			frameStart = frame.Position
		end
	end)
	header.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then draggingWindow = false end
	end)
	table.insert(viewerConnections, UserInputService.InputChanged:Connect(function(input)
		if not screenGui.Parent then return end
		if draggingWindow and input.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = input.Position - dragStart
			frame.Position = UDim2.new(
				frameStart.X.Scale,
				frameStart.X.Offset + delta.X,
				frameStart.Y.Scale,
				frameStart.Y.Offset + delta.Y
			)
		end
	end))

	close.MouseButton1Click:Connect(function()
		screenGui:Destroy()
		if OnlineBuilds.ViewerGui == screenGui then OnlineBuilds.ViewerGui = nil end
	end)

	local missingCount = 0
	for _ in pairs(missing) do missingCount = missingCount + 1 end
	return true, shown, missingCount
end

