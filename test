local updateRemoteStatus

local function savePlacementCache(hashName, hashValue)
	writefile(PLACE_CACHE_FILE, HttpService:JSONEncode({
		placeVersion = game.PlaceVersion,
		hashName     = hashName,
		hashValue    = hashValue
	}))
end

local function loadPlacementCache()
	if not isfile(PLACE_CACHE_FILE) then return nil end
	local ok, decoded = pcall(function() return HttpService:JSONDecode(readfile(PLACE_CACHE_FILE)) end)
	if not ok or type(decoded) ~= "table" then return nil end
	if tonumber(decoded.placeVersion) ~= game.PlaceVersion then return nil end
	if type(decoded.hashName) ~= "string" or type(decoded.hashValue) ~= "string" then return nil end
	return decoded.hashName, decoded.hashValue
end

local function setActivePlacementHash(hashName, hashValue, sourceLabel)
	if type(hashName) ~= "string" or hashName == "" or type(hashValue) ~= "string" or hashValue == "" then
		return false
	end
	placementHashName  = hashName
	placementHashValue = hashValue
	savePlacementCache(placementHashName, placementHashValue)
	setRemoteDebugValue("BlockPlaceRemote",  "CLIENT_BLOCK_PLACE_REQUEST")
	setRemoteDebugValue("BlockPlaceHashData", placementHashName)
	setRemoteDebugValue("BlockPlaceHash",     placementHashValue)
	updateRemoteStatus("placement hash ready (" .. tostring(sourceLabel or "unknown") .. ")")
	return true
end

local function tryCapturePlacementHashFromPayload(payload, sourceLabel)
	if type(payload) ~= "table" then return false end
	if not payload.cframe or not payload.blockType then return false end
	for key, value in pairs(payload) do
		if type(key) == "string" and type(value) == "string" then
			if key ~= "blockType" and key ~= "cframe" and key ~= "upperBlock" then
				if setActivePlacementHash(key, value, sourceLabel) then
					task.spawn(function()
						notify("Remote", "Captured placement hash from a manual block place.", 4)
					end)
					return true
				end
			end
		end
	end
	return false
end

local function tryCapturePlacementHashFromArgs(args, sourceLabel)
	for _, arg in ipairs(args) do
		if tryCapturePlacementHashFromPayload(arg, sourceLabel) then return true end
	end
	return false
end

local function installPlacementCaptureHook()
	if placementCaptureInstalled then return true end
	if type(hookmetamethod) ~= "function" or type(getnamecallmethod) ~= "function" or type(newcclosure) ~= "function" then
		return false, "Your executor cannot hook __namecall for manual placement capture."
	end

	local oldNamecall
	oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
		local args   = { ... }
		local method = getnamecallmethod()
		if method == "InvokeServer"
			and typeof(self) == "Instance"
			and self.Name == "CLIENT_BLOCK_PLACE_REQUEST"
		then
			local isGameCall = true
			if type(checkcaller) == "function" then isGameCall = not checkcaller() end
			if isGameCall then tryCapturePlacementHashFromArgs(args, "manual placement") end
		end
		return oldNamecall(self, ...)
	end))

	placementCaptureInstalled = true
	return true
end

local function discoverPlacementHash()
	if type(getgc) ~= "function" or type(getconstants) ~= "function" or type(getfenv) ~= "function" then
		return nil, "Your executor is missing getgc/getconstants/getfenv."
	end
	local blockController = getBlockControllerScript()
	if not blockController then return nil, "Could not find the block-controller script." end

	for _, fn in pairs(getgc(true)) do
		if type(fn) == "function" then
			local env = getfenv(fn)
			if env and env.script == blockController then
				local ok, constants = pcall(getconstants, fn)
				if ok and type(constants) == "table" then
					local left   = constants[23]
					local rightA = constants[25]
					local rightB = constants[26]
					if type(left) == "string" and type(rightA) == "string" and type(rightB) == "string" then
						return left, rightA .. rightB
					end
				end
			end
		end
	end
	return nil, "Could not discover the placement hash."
end

updateRemoteStatus = function(text)
	RemoteStatus:SetDesc(tostring(text))
end

local function resolvePlacementHash(forceRefresh)
	if placementHashName and placementHashValue and not forceRefresh then return true end
	if not forceRefresh then
		local cachedName, cachedValue = loadPlacementCache()
		if cachedName and cachedValue then
			setActivePlacementHash(cachedName, cachedValue, "cache")
			return true
		end
	end
	local hashName, hashValueOrError = discoverPlacementHash()
	if not hashName then updateRemoteStatus(hashValueOrError); return false, hashValueOrError end
	setActivePlacementHash(hashName, hashValueOrError, "auto scan")
	return true
end

local function placeBlockRequest(blockCFrame, blockName)
	if not netManaged then return false, "NetManaged could not be found." end
	if not placementHashName or not placementHashValue then
		local ok, err = resolvePlacementHash(false)
		if not ok then return false, err end
	end
	local placeRemote = netManaged:FindFirstChild("CLIENT_BLOCK_PLACE_REQUEST")
	if not placeRemote then return false, "CLIENT_BLOCK_PLACE_REQUEST was not found." end

	local args = {
		upperBlock = false,
		cframe     = blockCFrame,
		blockType  = normalizePlaceBlockName(blockName)
	}
	args[placementHashName] = placementHashValue
	return pcall(function() placeRemote:InvokeServer(args) end)
end

local function placeBlockBatch(batch)
	local completed = 0
	local placed = 0
	local done = Instance.new("BindableEvent")

	for _, entry in ipairs(batch) do
		task.spawn(function()
			local success = false
			if entry.block and entry.block.Parent then
				success = placeBlockRequest(entry.block.CFrame, entry.block.Name)
			end
			entry.success = success
			if success then placed = placed + 1 end
			completed = completed + 1
			if completed >= #batch then done:Fire() end
		end)
	end

	if #batch > 0 then done.Event:Wait() end
	done:Destroy()
	return placed
end

