-- ─── Helper: island detection ─────────────────────────────────────────────────

local function getLocalIsland()
	local islandsFolder = Workspace:FindFirstChild("Islands")
	if not islandsFolder then return nil end
	local userId = tostring(LocalPlayer.UserId)
	for _, island in ipairs(islandsFolder:GetChildren()) do
		if island.Name:find(userId) then return island end
	end
	local children = islandsFolder:GetChildren()
	if #children == 1 then return children[1] end
	return nil
end

local function isTotemBlock(blockPart)
	if not blockPart then return false end
	local name = blockPart.Name:lower()
	for _, pattern in ipairs(TOTEM_NAME_PATTERNS) do
		if name:find(pattern) then return true end
	end
	return false
end

-- ─── Totem scanning ───────────────────────────────────────────────────────────

local function getSelectedPartSet()
	if not selectionPart then return nil, "Pick a selection region first." end
	local selected = {}
	for _, part in ipairs(Workspace:GetPartsInPart(selectionPart)) do
		selected[part] = true
		if part.Parent and part.Parent:IsA("BasePart") then
			selected[part.Parent] = true
		end
	end
	return selected
end

local function scanTotems(selectedOnly)
	local island = getLocalIsland()
	if not island then return nil, "Could not find your island in Workspace.Islands." end

	local blocksContainer = island:FindFirstChild("Blocks")
	if not blocksContainer then return nil, "Island has no Blocks folder." end

	local selectedParts, selectedErr = nil, nil
	if selectedOnly then
		selectedParts, selectedErr = getSelectedPartSet()
		if not selectedParts then return nil, selectedErr end
	end

	local totems = {}
	for _, block in ipairs(blocksContainer:GetChildren()) do
		if isTotemBlock(block) and (not selectedOnly or selectedParts[block]) then
			local upgradeProgress = block:FindFirstChild("UpgradeProgress")
			local upgrades = {}
			if upgradeProgress then
				for _, upgradeType in ipairs(TOTEM_UPGRADE_TYPES) do
					local val = upgradeProgress:FindFirstChild(upgradeType)
					upgrades[upgradeType] = val and tonumber(val.Value) or 0
				end
			else
				for _, upgradeType in ipairs(TOTEM_UPGRADE_TYPES) do
					upgrades[upgradeType] = 0
				end
			end
			table.insert(totems, { instance = block, name = block.Name, upgrades = upgrades })
		end
	end

	return totems, nil
end

local function formatTotemScanStatus(totems)
	if not totems or #totems == 0 then return "No totem blocks found on your island." end
	local lines = { string.format("Found %d totem(s):", #totems), "" }
	for _, t in ipairs(totems) do
		table.insert(lines, "» " .. t.name)
		for _, upgradeType in ipairs(TOTEM_UPGRADE_TYPES) do
			table.insert(lines, string.format("  %s: %d", upgradeType, t.upgrades[upgradeType] or 0))
		end
		table.insert(lines, "")
	end
	return table.concat(lines, "\n")
end

-- ─── Totem persistent save/load (file-based, survives session) ───────────────
--[[
	All totem saves are stored in a single JSON file at TOTEM_STORAGE_FILE.
	Structure:  { [slotName] = { savedAt = timestamp, totems = [ {name, upgrades}, ... ] } }

	This mirrors the spirit of the persistent storage API the user asked for —
	every save slot is keyed by a user-chosen name so nothing overwrites another.
]]

local function readTotemStore()
	if not isfile(TOTEM_STORAGE_FILE) then return {} end
	local ok, decoded = pcall(function()
		return HttpService:JSONDecode(readfile(TOTEM_STORAGE_FILE))
	end)
	if ok and type(decoded) == "table" then return decoded end
	return {}
end

local function writeTotemStore(store)
	writefile(TOTEM_STORAGE_FILE, HttpService:JSONEncode(store))
end

local function listTotemSlots()
	local store = readTotemStore()
	local slots = {}
	for k in pairs(store) do table.insert(slots, k) end
	table.sort(slots)
	return slots
end

local totemSaveSlotName = "default"

local function saveTotemSlot(slotName)
	slotName = tostring(slotName or "default"):gsub("^%s+", ""):gsub("%s+$", "")
	if slotName == "" then slotName = "default" end

	local totems, err = scanTotems(true)
	if not totems then return false, err end
	if #totems == 0 then return false, "No totem blocks found inside the selected region." end

	local store = readTotemStore()
	local totemData = {}
	for _, t in ipairs(totems) do
		table.insert(totemData, { name = t.name, upgrades = t.upgrades })
	end

	store[slotName] = {
		savedAt = os.time(),
		totems  = totemData
	}
	writeTotemStore(store)
	return true, #totems
end

local function loadTotemSlot(slotName)
	slotName = tostring(slotName or "default"):gsub("^%s+", ""):gsub("%s+$", "")
	local store = readTotemStore()
	local entry = store[slotName]
	if not entry then
		return nil, "Slot '" .. slotName .. "' not found. Save it first."
	end
	return entry.totems, entry.savedAt
end

local function deleteTotemSlot(slotName)
	local store = readTotemStore()
	if not store[slotName] then return false, "Slot not found." end
	store[slotName] = nil
	writeTotemStore(store)
	return true
end

local function formatTotemSlotList()
	local slots = listTotemSlots()
	if #slots == 0 then return "No saved totem slots yet." end
	local store = readTotemStore()
	local lines = { string.format("%d slot(s):", #slots) }
	for _, slotName in ipairs(slots) do
		local entry = store[slotName]
		local count = entry and entry.totems and #entry.totems or 0
		local saved = entry and entry.savedAt or 0
		table.insert(lines, string.format("» %s  (%d totem(s), saved %s)", slotName, count, os.date("%H:%M:%S", saved)))
	end
	return table.concat(lines, "\n")
end

-- Also keep the old schematic-file totem embed (backwards compatible)
local function saveTotemDataToFile(fileName)
	local totems, err = scanTotems(true)
	if not totems then return false, err end
	if #totems == 0 then return false, "No totem blocks found inside the selected region." end

	local path    = SCHEMATIC_FOLDER .. "/" .. ensureJsonExtension(fileName)
	local existing = {}
	if isfile(path) then
		local ok, decoded = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
		if ok and type(decoded) == "table" then existing = decoded end
	end

	local totemData = {}
	for _, t in ipairs(totems) do
		table.insert(totemData, { name = t.name, upgrades = t.upgrades })
	end
	existing.TotemData = totemData
	writefile(path, HttpService:JSONEncode(existing))
	return true, #totems
end

local function loadTotemDataFromFile(fileName)
	local path = SCHEMATIC_FOLDER .. "/" .. ensureJsonExtension(fileName)
	if not isfile(path) then return nil, "File not found: " .. fileName end

	local ok, decoded = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
	if not ok or type(decoded) ~= "table" then return nil, "Could not parse schematic file." end
	if not decoded.TotemData or #decoded.TotemData == 0 then return nil, "No TotemData in this schematic." end
	return decoded.TotemData, nil
end

-- ─── Totem upgrader ───────────────────────────────────────────────────────────

local function autoUpgradeTotems(targetTypeName, upgradeTypes, maxLevel)
	if totemUpgradeInProgress then notify("Totems", "An upgrade loop is already running.", 3); return end

	local upgradeRemote = netManaged and netManaged:FindFirstChild("UpgradeBlock")
	if not upgradeRemote then notify("Totems", "UpgradeBlock remote not found.", 5); return end

	totemUpgradeInProgress = true

	task.spawn(function()
		local totalCalls = 0
		while totemUpgradeInProgress do
			local totems, err = scanTotems()
			if not totems or #totems == 0 then
				TotemUpgradeStatus:SetDesc("No totems found — stopping.\n" .. tostring(err or ""))
				break
			end

			local madeAnyCall = false
			for _, t in ipairs(totems) do
				if not totemUpgradeInProgress then break end
				for _, upgradeType in ipairs(upgradeTypes) do
					if not totemUpgradeInProgress then break end
					local currentLevel = t.upgrades[upgradeType] or 0
					if maxLevel <= 0 or currentLevel < maxLevel then
						local ok, callErr = pcall(function()
							upgradeRemote:InvokeServer(t.instance, targetTypeName, upgradeType)
						end)
						if ok then
							totalCalls   = totalCalls + 1
							madeAnyCall  = true
							TotemUpgradeStatus:SetDesc(string.format(
								"Upgrading %s → %s (%s)\nTotal calls: %d",
								t.name, targetTypeName, upgradeType, totalCalls
							))
						else
							TotemUpgradeStatus:SetDesc(string.format(
								"Error on %s (%s): %s", t.name, upgradeType, tostring(callErr)
							))
						end
						task.wait(totemUpgradeDelay)
					end
				end
			end

			if not madeAnyCall then
				TotemUpgradeStatus:SetDesc(string.format(
					"All totems at max level (%d). Done.\nTotal calls: %d", maxLevel, totalCalls
				))
				break
			end
			task.wait(0.1)
		end

		totemUpgradeInProgress = false
		notify("Totems", string.format("Upgrade loop finished. Total calls: %d", totalCalls), 4)
	end)
end

-- ─── Block helpers ────────────────────────────────────────────────────────────

local function isThreeBlock(part)
	return part
		and part:IsA("BasePart")
		and math.abs(part.Size.X - BLOCK_SIZE) <= 0.1
		and math.abs(part.Size.Y - BLOCK_SIZE) <= 0.1
		and math.abs(part.Size.Z - BLOCK_SIZE) <= 0.1
end

local function isIslandBlockPart(part)
	return isThreeBlock(part)
		and (
			(part.Parent and part.Parent.Name == "Blocks")
			or part:FindFirstChild("Health") ~= nil
		)
end

local function normalizeClickedBlock(target)
	if not target then return nil end
	if target.Name == "Top" and target.Parent and target.Parent:IsA("BasePart") then
		target = target.Parent
	end
	if isIslandBlockPart(target) then return target end
	if target.Parent and target.Parent:IsA("BasePart") and isIslandBlockPart(target.Parent) then
		return target.Parent
	end
	return nil
end

local function snapToGrid(pos)
	return Vector3.new(
		math.round(pos.X / BLOCK_SIZE) * BLOCK_SIZE,
		math.round(pos.Y / BLOCK_SIZE) * BLOCK_SIZE,
		math.round(pos.Z / BLOCK_SIZE) * BLOCK_SIZE
	)
end

local function createMarker(name, color)
	local marker = Workspace:FindFirstChild(name)
	if not marker then
		marker            = Instance.new("Part")
		marker.Name       = name
		marker.Size       = Vector3.new(BLOCK_SIZE, BLOCK_SIZE, BLOCK_SIZE)
		marker.Anchored   = true
		marker.CanCollide = false
		marker.CastShadow = false
		marker.Material   = Enum.Material.Neon
		marker.Transparency = 0.35
		marker.Parent     = Workspace
	end
	marker.Color = color
	return marker
end

