-- ─── Auto-upgrade from saved schematic TotemData ─────────────────────────────
--[[
	After a paste finishes, if the loaded schematic JSON has TotemData embedded,
	we automatically upgrade each matching totem on the island to the saved level.
	This fires UpgradeBlock exactly (savedLevel - currentLevel) times per stat.
]]
local function autoUpgradeFromSchematicTotemData()
	local upgradeRemote = netManaged and netManaged:FindFirstChild("UpgradeBlock")
	if not upgradeRemote then
		notify("Totems", "UpgradeBlock remote not found — skipping auto-upgrade.", 4)
		return
	end

	-- Load the TotemData from the current schematic file
	local path = getSchematicPath(currentFileName)
	if not isfile(path) then return end

	local ok, decoded = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
	if not ok or type(decoded) ~= "table" or not decoded.TotemData or #decoded.TotemData == 0 then
		return  -- No embedded totem data — nothing to do
	end

	local savedTotemData = decoded.TotemData
	notify("Totems", string.format("Auto-upgrading %d totem(s) from schematic data…", #savedTotemData), 4)
	TotemUpgradeStatus:SetDesc("Auto-upgrade from schematic running…")

	task.spawn(function()
		local totalCalls = 0

		-- Scan live island totems so we have real Instance references
		local liveTotems, err = scanTotems()
		if not liveTotems or #liveTotems == 0 then
			TotemUpgradeStatus:SetDesc("Auto-upgrade: no live totems found.\n" .. tostring(err or ""))
			return
		end

		-- Build a lookup from name → live totem entry
		local liveByName = {}
		for _, lt in ipairs(liveTotems) do
			liveByName[lt.name] = lt
		end

		for _, saved in ipairs(savedTotemData) do
			local live = liveByName[saved.name]
			if not live then
				notify("Totems", "Totem not found on island: " .. tostring(saved.name), 3)
			else
				for _, upgradeType in ipairs(TOTEM_UPGRADE_TYPES) do
					local savedLevel = (saved.upgrades and saved.upgrades[upgradeType]) or 0
					local liveLevel  = live.upgrades[upgradeType] or 0
					local needed     = savedLevel - liveLevel

					for i = 1, needed do
						pcall(function()
							upgradeRemote:InvokeServer(live.instance, totemUpgradeTarget, upgradeType)
						end)
						totalCalls = totalCalls + 1
						TotemUpgradeStatus:SetDesc(string.format(
							"Auto-upgrading %s → %s (%s)  %d/%d\nTotal calls: %d",
							live.name, totemUpgradeTarget, upgradeType, i, needed, totalCalls
						))
						task.wait(totemUpgradeDelay)
					end
				end
			end
		end

		TotemUpgradeStatus:SetDesc(string.format("Auto-upgrade done. Total calls: %d", totalCalls))
		notify("Totems", string.format("Auto-upgrade finished. %d call(s) fired.", totalCalls), 4)
	end)
end

