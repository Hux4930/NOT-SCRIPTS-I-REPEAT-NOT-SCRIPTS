function getPreviewBlockHitboxes(block)
	local hitboxes = {}
	local hasHitboxes = false

	for _, child in ipairs(block:GetChildren()) do
		if child:IsA("BasePart") and child:GetAttribute("IsPreviewHitbox") == true then
			hasHitboxes = true
			local minPos, maxPos = getPartAabb(child)
			table.insert(hitboxes, { part = child, min = minPos, max = maxPos })
		end
	end

	if not hasHitboxes then
		local minPos, maxPos = getPartAabb(block)
		table.insert(hitboxes, { part = block, min = minPos, max = maxPos })
	end
	return hitboxes
end

function hitboxesOverlapEnough(first, second)
	local overlapX = math.min(first.max.X, second.max.X) - math.max(first.min.X, second.min.X)
	local overlapY = math.min(first.max.Y, second.max.Y) - math.max(first.min.Y, second.min.Y)
	local overlapZ = math.min(first.max.Z, second.max.Z) - math.max(first.min.Z, second.min.Z)
	return overlapX > HITBOX_MERGE_OVERLAP
		and overlapY > HITBOX_MERGE_OVERLAP
		and overlapZ > HITBOX_MERGE_OVERLAP
end

function previewEntriesOverlapEnough(firstEntry, secondEntry)
	for _, firstHitbox in ipairs(firstEntry.hitboxes) do
		for _, secondHitbox in ipairs(secondEntry.hitboxes) do
			if hitboxesOverlapEnough(firstHitbox, secondHitbox) then
				return true
			end
		end
	end
	return false
end

function getHitboxCandidateCells(hitboxes)
	local cells = {}
	for _, hitbox in ipairs(hitboxes) do
		local minX = math.floor(hitbox.min.X / BLOCK_SIZE)
		local minY = math.floor(hitbox.min.Y / BLOCK_SIZE)
		local minZ = math.floor(hitbox.min.Z / BLOCK_SIZE)
		local maxX = math.floor(hitbox.max.X / BLOCK_SIZE)
		local maxY = math.floor(hitbox.max.Y / BLOCK_SIZE)
		local maxZ = math.floor(hitbox.max.Z / BLOCK_SIZE)

		for x = minX, maxX do
			for y = minY, maxY do
				for z = minZ, maxZ do
					cells[string.format("%d:%d:%d", x, y, z)] = true
				end
			end
		end
	end
	return cells
end

local function buildPasteQueues(previewBlocks)
	local entries = {}
	local parent = {}
	local firstIndexesByCell = {}

	local function find(index)
		while parent[index] ~= index do
			parent[index] = parent[parent[index]]
			index = parent[index]
		end
		return index
	end

	local function union(a, b)
		local rootA = find(a)
		local rootB = find(b)
		if rootA ~= rootB then parent[rootB] = rootA end
	end

	for index, block in ipairs(previewBlocks) do
		local blockCFrame = block.CFrame
		local rootKey = block:GetAttribute("StackPositionKey") or getGridKey(blockCFrame.Position)

		parent[index] = index
		entries[index] = {
			block = block,
			name = block.Name,
			cframe = blockCFrame,
			gridKey = rootKey,
			mergeKey = rootKey,
			hitboxes = getPreviewBlockHitboxes(block)
		}

		local candidateIndexes = {}
		local candidateCells = getHitboxCandidateCells(entries[index].hitboxes)
		for cellKey in pairs(candidateCells) do
			local cellIndexes = firstIndexesByCell[cellKey]
			if cellIndexes then
				for _, otherIndex in ipairs(cellIndexes) do
					candidateIndexes[otherIndex] = true
				end
			end
		end

		for otherIndex in pairs(candidateIndexes) do
			if previewEntriesOverlapEnough(entries[index], entries[otherIndex]) then
				union(index, otherIndex)
			end
		end

		for cellKey in pairs(candidateCells) do
			if not firstIndexesByCell[cellKey] then
				firstIndexesByCell[cellKey] = {}
			end
			table.insert(firstIndexesByCell[cellKey], index)
		end
	end

	local groups = {}
	local order = {}
	for index, entry in ipairs(entries) do
		local root = find(index)
		if not groups[root] then
			groups[root] = {}
			groups[root].gridKey = entry.mergeKey or entry.gridKey
			table.insert(order, root)
		end
		table.insert(groups[root], entry)
	end

	table.sort(order, function(a, b)
		local first = groups[a][1].block.Position
		local second = groups[b][1].block.Position
		if first.Y ~= second.Y then return first.Y < second.Y end
		if first.X ~= second.X then return first.X < second.X end
		return first.Z < second.Z
	end)

	local normal = {}
	local stacked = {}
	for _, key in ipairs(order) do
		local group = groups[key]
		if #group == 1 then
			table.insert(normal, group[1])
		else
			group.isStackedCell = true
			table.insert(stacked, group)
		end
	end
	return normal, stacked
end

local function countStackedEntries(stackedBatches)
	local total = 0
	for _, batch in ipairs(stackedBatches) do
		total = total + #batch
	end
	return total
end

local function groupStackedBatchesBySize(stackedBatches)
	local batchesBySize = {}
	local sizes = {}
	for _, batch in ipairs(stackedBatches) do
		local size = #batch
		if not batchesBySize[size] then
			batchesBySize[size] = {}
			table.insert(sizes, size)
		end
		table.insert(batchesBySize[size], batch)
	end
	table.sort(sizes)
	return batchesBySize, sizes
end

local function removeSuccessfulPreviewBlocks(batch)
	for _, entry in ipairs(batch) do
		if entry.success and entry.block and entry.block.Parent then
			entry.block:Destroy()
		end
	end
	updatePreviewStatus()
	updateBlocksStatus()
end

local function setPasteStatus(text)
	PasteStatus:SetDesc(tostring(text or "idle"))
end

local function requestPasteStep(action)
	if not pasteInProgress or not pasteWaitingForStep then
		notify("Paste", "No stacked batch is waiting for Next or Redo.", 3)
		return
	end
	pasteStepAction = action
	pasteStepEvent:Fire()
end

local function stopPaste()
	if pasteInProgress then
		pasteInProgress = false
		pasteStepEvent:Fire()
		notify("Paste", "Paste stopped.", 3)
	else
		notify("Paste", "No paste is running.", 3)
	end
end

local function waitForPasteStep()
	while pasteInProgress do
		if pasteStepAction then
			local action = pasteStepAction
			pasteStepAction = nil
			pasteWaitingForStep = false
			return action
		end
		pasteStepEvent.Event:Wait()
	end
	return "stop"
end

-- ─── Mouse click picking ──────────────────────────────────────────────────────

Mouse.Button1Down:Connect(function()
	local clickedHandle = nil
	if dragPreviewEnabled then
		for _, handle in pairs(previewDragHandles) do
			if Mouse.Target == handle.knob or Mouse.Target == handle.line then
				clickedHandle = handle
				break
			end
		end
	end

	if clickedHandle then
		local blocks = getPreviewBlocks()
		if #blocks == 0 then return end
		previewDragActive = true
		previewDragStartHit = Mouse.Hit.Position
		previewDragStartCFrames = {}
		previewDragAxis = clickedHandle.axis
		for _, block in ipairs(blocks) do
			table.insert(previewDragStartCFrames, { block = block, cframe = block.CFrame })
		end
		DragStatus:SetDesc("pulling handle; snap is 3 studs")
		return
	end

	if not selectionPickMode then return end
	local clickedBlock = normalizeClickedBlock(Mouse.Target)
	if not clickedBlock then notify("Selection", "Click a 3x3 island block.", 3); return end

	if selectionPickMode == "start" then
		selectionStartBlock = clickedBlock
		selectionStartPos   = nil
		startMarker         = createMarker(START_MARKER_NAME, Color3.fromRGB(70, 170, 255))
		startMarker.CFrame  = clickedBlock.CFrame
		notify("Selection", "Start corner picked.", 2)
	elseif selectionPickMode == "end" then
		selectionEndBlock  = clickedBlock
		selectionEndPos    = nil
		endMarker          = createMarker(END_MARKER_NAME, Color3.fromRGB(255, 95, 95))
		endMarker.CFrame   = clickedBlock.CFrame
		notify("Selection", "End corner picked.", 2)
	end

	selectionPickMode = nil
	local startPos = selectionStartPos or (selectionStartBlock and selectionStartBlock.Position)
	local endPos   = selectionEndPos   or (selectionEndBlock   and selectionEndBlock.Position)
	if startPos and endPos then rebuildSelectionPart() end
	updateSelectionStatus()
end)

Mouse.Move:Connect(function()
	if not previewDragActive or not previewDragStartHit or not previewDragStartCFrames or not previewDragAxis then return end
	local hit = Mouse.Hit.Position
	local rawDelta = hit - previewDragStartHit
	local snappedStuds = math.round(rawDelta:Dot(previewDragAxis) / BLOCK_SIZE) * BLOCK_SIZE
	local offset = previewDragAxis * snappedStuds
	for _, entry in ipairs(previewDragStartCFrames) do
		if entry.block and entry.block.Parent then
			entry.block.CFrame = entry.cframe + offset
		end
	end
	updatePreviewDragPart()
end)

Mouse.Button1Up:Connect(function()
	if not previewDragActive then return end
	previewDragActive = false
	previewDragStartHit = nil
	previewDragStartCFrames = nil
	previewDragAxis = nil
	refreshPreviewStackKeys()
	updatePreviewStatus()
	DragStatus:SetDesc("drag complete")
end)

