local function normalizeConsoleCommand(message)
	local text = tostring(message or ""):lower():gsub("^%s+", ""):gsub("%s+$", "")
	text = text:gsub("^%[.-%]%s*", "")
	text = text:gsub("^cmd:%s*", "")
	if text == "next" or text == "n" or text == "build next" then return "next" end
	if text == "redo" or text == "r" or text == "retry" or text == "repeat" then return "redo" end
	if text == "stop" or text == "cancel" then return "stop" end
	if text == "paste" or text == "start" or text == "start build" then return "paste" end
	return nil
end

local function runConsolePasteCommand(command)
	local now = os.clock()
	if command == lastConsoleCommand and (now - lastConsoleCommandAt) < 0.05 then return end
	lastConsoleCommand = command
	lastConsoleCommandAt = now

	if command == "next" then
		requestPasteStep("next")
	elseif command == "redo" then
		requestPasteStep("redo")
	elseif command == "stop" then
		stopPaste()
	elseif command == "paste" then
		pastePreview()
	end
end

LogService.MessageOut:Connect(function(message)
	if not consoleCommandMode then return end
	local command = normalizeConsoleCommand(message)
	if command then runConsolePasteCommand(command) end
end)

