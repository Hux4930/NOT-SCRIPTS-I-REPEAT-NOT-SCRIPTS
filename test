local function resolvePlacementHash(forceRefresh)
	if placementHashName and placementHashValue and not forceRefresh then return true end
	if not forceRefresh then
		local cachedName, cachedValue = loadPlacementCache()
		if cachedName and cachedValue then
			setActivePlacementHash(cachedName, cachedValue, "cache")
			return true
		end
	end
	local hashName, hashValueOrError = discoverPlacementHash()
	if not hashName then updateRemoteStatus(hashValueOrError); return false, hashValueOrError end
	setActivePlacementHash(hashName, hashValueOrError, "auto scan")
	return true
end

local function placeBlockRequest(blockCFrame, blockName)
	if not netManaged then return false, "NetManaged could not be found." end
	if not placementHashName or not placementHashValue then
		local ok, err = resolvePlacementHash(false)
		if not ok then return false, err end
	end
	local placeRemote = netManaged:FindFirstChild("CLIENT_BLOCK_PLACE_REQUEST")
	if not placeRemote then return false, "CLIENT_BLOCK_PLACE_REQUEST was not found." end

	local args = {
		upperBlock = false,
		cframe     = blockCFrame,
		blockType  = normalizePlaceBlockName(blockName)
	}
	args[placementHashName] = placementHashValue
	return pcall(function() placeRemote:InvokeServer(args) end)
end

